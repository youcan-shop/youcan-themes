{% comment %}
  Renders cart bundle item template (cart drawer)

  Accepts:
  - product: {Object} cart item info

  Usage:
  {% render 'core.cart-drawer-bundle-item', product: {...} %}
{% endcomment %}

<div class="item">
  <div class="image" ui-cart-item="image">
    <img
      src="{{ product.image }}"
      alt="{{ product.name }}"
      height="100%"
      width="100%"
      loading="eager"
      {% if product.image contains '/store-front/images/product-default' %}
        hidden
      {% endif %}
    >
    {% if product.image contains '/store-front/images/product-default' %}
      {% render 'misc.image-fallback' %}
    {% else %}
      {% render 'misc.image-fallback', hidden: true %}
    {% endif %}
  </div>
  <div class="content">
    <div class="info">
      <div class="bio">
        <a
          class="title"
          ui-slot="link-button"
          data-variant="black"
          data-size="md"
          title="{{ product.name }}"
          ui-cart-item="title"
          href="{{ product.url }}"
        >
          {{ product.name }}
        </a>
        <span
          class="variants"
          ui-cart-item="variant"
          {% if product.variations == null or product.variations.default %}
            hidden
          {% endif %}
        >
          {% for variant in product.variations %}
            <span>{{ variant[1] }}</span>
            {% unless forloop.index == product.variations.size - 1 %}
              <span>/</span>
            {% endunless %}
          {% endfor %}
        </span>
        <span class="price" ui-cart-item="price">
          {% if product.price %}
            {{ product.price | default: 0 | money }}
          {% else %}
            {{ 'bundles.free' | t }}
          {% endif %}
        </span>
      </div>
    </div>
  </div>
</div>
