{% comment %}
  Renders cart bundle item template (cart page)

  Accepts:
  - product: {Object} cart item info

  Usage:
  {% render 'core.cart-item', product: {...} %}
{% endcomment %}

<tr class="bundle-item">
  <td></td>
  <td>
    <div class="product">
      <div class="image" ui-cart-item="image">
        <img
          src="{{ product.image }}"
          alt="{{ product.name }}"
          height="100%"
          width="100%"
          loading="lazy"
          {% if product.image contains '/store-front/images/product-default' %}
            hidden
          {% endif %}
        >
        {% if product.image contains '/store-front/images/product-default' %}
          {% render 'misc.image-fallback' %}
        {% else %}
          {% render 'misc.image-fallback', hidden: true %}
        {% endif %}
      </div>
      <div class="info">
        <a
          class="title"
          href="{{ product.url }}"
          ui-slot="link-button"
          data-size="md"
          ui-cart-item="title"
        >
          {{ product.name }}
        </a>
        <span
          class="variants"
          ui-cart-item="variant"
          {% if product.variations == null or product.variations.default %}
            hidden
          {% endif %}
        >
          {% for variant in product.variations %}
            <span>{{ variant[1] }}</span>
            {% unless forloop.index == product.variations.size - 1 %}
              <span>/</span>
            {% endunless %}
          {% endfor %}
        </span>
      </div>
    </div>
  </td>
  <td>
    <span
      class="price"
      ui-cart-item="price"
      {% unless product.price %}
        data-free
      {% endunless %}
    >
      {% if product.price %}
        {{ product.price | default: 0 | money }}
      {% else %}
        {{ 'bundles.free' | t }}
      {% endif %}
    </span>
  </td>
  <td>
    <span class="quantity" ui-cart-item="quantity">{{ product.quantity }}</span>
  </td>
  <td>
    {% assign subtotal = product.quantity | times: product.price %}
    <span class="subtotal" ui-cart-item="subtotal">
      {% if subtotal %}
        {{ subtotal | money }}
      {% else %}
        {{ 'bundles.free' | t }}
      {% endif %}
    </span>
  </td>
</tr>
