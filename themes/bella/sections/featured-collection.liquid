{{ 'section.featured-collection.css' | asset_url | stylesheet_tag }}

<div
  ui-section="featured-collection"
  {% if section.settings.override_global_colors %}
    style="
      --brand-hue: {{ section.settings.main_color.hue }};
      --brand-saturation: {{ section.settings.main_color.saturation }}%;
      --brand-lightness: {{ section.settings.main_color.lightness }}%;

      {% if section.settings.main_color.hue == 0 and section.settings.main_color.lightness <= 20 %}
        --brand-raw-lightness: {{ section.settings.main_color.lightness }}%;
      {% endif %}
    "
    data-scoped-color
    data-intensity="{{ section.settings.color_intensity }}"
  {% endif %}
  data-top-spacing="{{ section.settings.top_spacing }}"
  data-bottom-spacing="{{ section.settings.bottom_spacing }}"
>
  <div ui-slot="head">
    <h4 class="heading">{{ section.settings.heading }}</h4>
    <h1 class="subheading">{{ section.settings.subheading }}</h1>
  </div>
  <div class="core-area">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'media' %}
          <div ui-block="content" {{ block.youcan_attributes }}>
            <div class="media">
              {% if block.settings.block_image.src %}
                <img
                  src="{{ block.settings.block_image.src }}"
                  alt="{{ block.settings.block_heading }}"
                  height="100%"
                  width="100%"
                  loading="lazy"
                >
              {% else %}
                {% render 'misc.image-fallback', icon_size: 100 %}
              {% endif %}
            </div>
            <div
              class="content"
              data-text-alignment="{{ block.settings.text_alignment }}"
              data-vertical-alignment="{{ block.settings.vertical_alignment }}"
            >
              <h4 class="subheading">{{ block.settings.block_heading }}</h4>
              <h1 class="heading">{{ block.settings.block_subheading }}</h1>
              <a
                class="cta"
                {% if block.settings.block_button_style == 'underline' %}
                  ui-slot="link-button"
                  data-underline="true"
                {% else %}
                  ui-slot="button"
                  data-variant="primary"
                {% endif %}
                {% if block.settings.block_button_style == 'primary' %}
                  data-mode="filled"
                {% elsif block.settings.block_button_style == 'secondary' %}
                  data-mode="lighter"
                {% endif %}
                data-size="lg"
                href="{{ block.settings.block_button_link }}"
              >
                {{ block.settings.block_button_label }}
              </a>
            </div>
          </div>
        {% else %}
          {% assign max_products = section.settings.max_products_to_show %}
          {% if block.settings.collection.id %}
            {% paginate collection.products by max_products id category_id: block.settings.collection.id %}
              <ul ui-block="products" {{ block.youcan_attributes }}>
                {% for product in items %}
                  {% render 'block.product' %}
                {% endfor %}
              </ul>
            {% endpaginate %}
          {% else %}
            <ul ui-block="products" {{ block.youcan_attributes }}>
              {% for product in (1..max_products) %}
                {% render 'block.product' %}
              {% endfor %}
            </ul>
          {% endif %}
      {% endcase %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "label": "t:sections.featured_collection.label",
  "templates": ["index"],
  "limit": 3,
  "max_blocks": 11,
  "settings": [
    {
      "type": "header",
      "content": "t:common.headers.colors"
    },
    {
      "type": "color",
      "id": "main_color",
      "label": "t:common.colors.main_color",
      "default": "#121212"
    },
    {
      "type": "select",
      "id": "color_intensity",
      "label": "t:common.colors.color_intensity",
      "options": [
        { "label": "t:common.colors.options.as_solid_bg", "value": "as-solid-bg" },
        { "label": "t:common.colors.options.as_light_bg", "value": "as-light-bg" },
        { "label": "t:common.colors.options.as_foreground", "value": "as-foreground" }
      ],
      "default": "as-foreground"
    },
    {
      "type": "checkbox",
      "id": "override_global_colors",
      "label": "t:common.colors.override_global_colors",
      "default": false
    },
    {
      "type": "header",
      "content": "t:common.headers.header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:common.header.heading",
      "default": "t:sections.featured_collection.default.heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:common.header.subheading",
      "default": "t:sections.featured_collection.default.subheading"
    },
    {
      "type": "header",
      "content": "t:common.headers.layout"
    },
    {
      "type": "range",
      "id": "max_products_to_show",
      "label": "t:common.globals.max_products",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "show_discount_badge",
      "label": "t:sections.featured_collection.show_discount_badge",
      "default": true
    },
    {
      "type": "header",
      "content": "t:common.headers.spacing"
    },
    {
      "type": "range",
      "id": "top_spacing",
      "label": "t:common.spacing.top_spacing",
      "min": 0,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "bottom_spacing",
      "label": "t:common.spacing.bottom_spacing",
      "min": 0,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "media",
      "label": "t:sections.featured_collection.blocks.media.label",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "t:common.headers.image"
        },
        {
          "type": "image_picker",
          "id": "block_image",
          "label": "t:common.globals.image"
        },
        {
          "type": "header",
          "content": "t:common.headers.header"
        },
        {
          "type": "text",
          "id": "block_heading",
          "label": "t:common.header.heading",
          "default": "t:sections.featured_collection.blocks.media.default.heading"
        },
        {
          "type": "text",
          "id": "block_subheading",
          "label": "t:common.header.subheading",
          "default": "t:sections.featured_collection.blocks.media.default.subheading"
        },
        {
          "type": "header",
          "content": "t:common.headers.button"
        },
        {
          "type": "text",
          "id": "block_button_label",
          "label": "t:common.button.label",
          "default": "t:sections.featured_collection.default.button"
        },
        {
          "type": "url",
          "id": "block_button_link",
          "label": "t:common.button.link",
          "default": "#"
        },
        {
          "type": "select",
          "id": "block_button_style",
          "options": [
            { "label": "t:common.button.style.options.primary", "value": "primary" },
            { "label": "t:common.button.style.options.secondary", "value": "secondary" },
            { "label": "t:common.button.style.options.underline", "value": "underline" }
          ],
          "label": "t:common.button.style.label",
          "default": "primary"
        },
        {
          "type": "header",
          "content": "t:common.headers.layout"
        },
        {
          "type": "select",
          "id": "text_alignment",
          "label": "t:common.globals.text_alignment",
          "options": [
            { "label": "t:common.layout.alignment.start", "value": "start" },
            { "label": "t:common.layout.alignment.center", "value": "center" },
            { "label": "t:common.layout.alignment.end", "value": "end" }
          ],
          "default": "center"
        },
        {
          "type": "select",
          "id": "vertical_alignment",
          "label": "t:common.globals.vertical_alignment",
          "options": [
            { "label": "t:common.layout.vertical_alignment.top", "value": "start" },
            { "label": "t:common.layout.vertical_alignment.middle", "value": "center" },
            { "label": "t:common.layout.vertical_alignment.bottom", "value": "end" }
          ],
          "default": "start"
        }
      ]
    },
    {
      "type": "collection_item",
      "label": "t:sections.featured_collection.blocks.collection.label",
      "limit": 1,
      "settings": [
        {
          "type": "category",
          "id": "collection",
          "label": "t:common.globals.collection"
        }
      ]
    }
  ]
}
{% endschema %}
