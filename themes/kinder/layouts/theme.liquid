<!doctype html>
{% assign lang = store.store_locale.iso_code %}
{% assign direction = 'ltr' %}

{% if lang == 'ar' %}
  {% assign direction = 'rtl' %}
{% endif %}

<html lang="{{ lang }}" dir="{{ direction }}">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="canonical" href="{{ request.url }}">

    {% render '_meta-tags' %}
    {% render '_config' %}
  </head>

  <body
    style="
      --brand-color: {{ settings.brand_color.hex }};
      --brand-lightness: {{ settings.brand_color.lightness | divided_by: 100.0 }};
      --on-brand: oklch(clamp(0, (0.6 - var(--brand-lightness)) * 99999, 1) 0 0deg);
    "
  >
    {% section 'announcement-bar' %}
    {% section 'header' %}

    <main id="main">
      {{ content_for_layout }}
    </main>

    {% section 'footer' %}
    {% render 'misc.toast' %}
  </body>
</html>
