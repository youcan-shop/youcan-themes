{% comment %}
  Renders an icon (HugeIcons)

  Accepts:
  - name: {String} Icon name
  - size: {Number} (optional) Icon size

  Usage:
  {% render 'misc-empty' %}
{% endcomment %}

<i
  class="hgi hgi-stroke hgi-rounded {{ name }}"
  style="
    font-weight: 400;
    {% if size %}
      font-size: {{ size }}px;
    {% endif %}
  "
></i>
