{{ 'core.cart-form.css' | asset_url | stylesheet_tag }}

<ui-cart-form>
  <template ui-cart-drawer="item">
    {% render 'core.cart-form-item', product: product %}
  </template>
  <ui-cart-drawer-items>
    {% for product in cart.items %}
      {% render 'core.cart-form-item', product: product %}
    {% endfor %}
  </ui-cart-drawer-items>

  {% unless cart.count > 0 %}
    {% assign empty_title = 'cart.empty.title' | t %}

    {% if section.settings.show_cart_recommendations %}
      {% assign empty_description = 'cart.empty.description' | t %}
    {% endif %}

    {% render 'misc.empty', heading: empty_title, subheading: empty_description %}
  {% else %}
    {% render 'misc.empty', heading: empty_title, subheading: empty_description, hidden: true %}
  {% endunless %}
  {% if section.settings.show_cart_recommendations %}
    <div class="collections">
      {% for i in (1..4) %}
        {% assign item = 'cart_collection_' | append: i %}
        {% assign collection = section.settings[item] %}

        {% if collection != blank %}
          <a class="collection" href="/collections/{{ collection.slug }}">
            <span class="name">{{ collection.name }}</span>
            <div
              ui-slot="button"
              data-mode="ghost"
              data-size="lg"
              data-as-icon
            >
              {% render 'misc.icon', name: 'hgi-arrow-right-01' %}
            </div>
          </a>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}
</ui-cart-form>
