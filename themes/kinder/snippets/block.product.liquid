{% comment %}
  Renders a product card (Block)

  Accepts:
  - product: {Object} Item info

  Usage:
  {% render 'block.product', product: {...} %}
{% endcomment %}

{% if product.has_only_default_variant %}
  {% assign default_variant = product.variants[0] %}
{% endif %}

{% if product.selected_or_first_available_variant %}
  {% assign default_variant = product.selected_or_first_available_variant %}
{% endif %}

{% assign price = default_variant.price | default: product.price %}
{% assign compare_at_price = default_variant.compare_at_price | default: product.compare_at_price %}

<li
  ui-carousel="item"
  ui-slot="carousel-item"
  ui-block="product"
  data-alignment="{{ settings.product_alignment }}"
  {{ product.youcan_attributes }}
>
  <div class="media" data-image-ratio="{{ settings.product_image_ratio }}">
    <a href="{{ product.url }}">
      {% if product.preview_image %}
        <img
          srcset="
            {{ product.preview_image.medium }} 480w,
            {{ product.preview_image.large }} 800w,
            {{ product.preview_image.original }} 1200w
          "
          sizes="
            (max-width: 640px) 50vw,
            (max-width: 768px) 33vw,
            (max-width: 1024px) 25vw,
            33vw
          "
          src="{{ product.preview_image.original }}"
          alt="{{ product.name }}"
          height="100%"
          width="100%"
          {% if template.name == 'collection' or template.name == 'search' and forloop.index < 5 %}
            loading="eager"
          {% else %}
            loading="lazy"
          {% endif %}
        >
      {% else %}
        {% render 'misc.image-fallback', icon_size: 40 %}
      {% endif %}
    </a>
  </div>
  <div class="content">
    <div class="stats">
      {% if settings.show_discount and compare_at_price %}
        {% assign savings = compare_at_price | minus: price | money %}

        <span>
          {{- 'product.save' | t }}
          {{ savings -}}
        </span>
      {% endif %}

      {% if settings.show_inventory and product.isTrackingInventory %}
        {% assign status_color = 'gray' %}
        {% assign status_text = 'product.inventory_out_of_stock' | t %}

        {% if default_variant.inventory > 1 %}
          {% assign status_color = 'orange' %}
          {% assign status_text = 'product.inventory_low_stock' | t %}
        {% endif %}

        {% if default_variant.inventory > 10 %}
          {% assign status_color = 'green' %}
          {% assign status_text = 'product.inventory_in_stock' | t %}
        {% endif %}

        <span ui-slot="badge" data-variant="ghost" data-size="sm" data-color="{{ status_color }}">{{ status_text }}</span>
      {% endif %}
    </div>
    <div class="info">
      <div class="price">
        <span class="current-price">
          {{ price | default: 0 | money }}
        </span>
        {% if compare_at_price %}
          <s class="compare-at-price">
            {{ compare_at_price | default: 0 | money }}
          </s>
        {% endif %}
      </div>
      <p class="name">
        {% assign placeholder = 'product.title' | t %}
        {{ product.name | default: placeholder }}
      </p>
      <div class="collections">
        {% assign visible_limit = 3 %}
        {% assign total_categories = product.categories | size %}
        {% assign remaining = total_categories | minus: visible_limit %}
        {% for category in product.categories limit: visible_limit %}
          <span class="category">
            {{ category.name }}
          </span>
          {% unless forloop.last and remaining <= 0 %}
            <span>, &nbsp;</span>
          {% endunless %}
        {% endfor %}
        {% if remaining > 0 %}
          <span class="category category--more">+{{ remaining }}</span>
        {% endif %}
      </div>
    </div>
    {% if settings.enable_quick_add or settings.show_quantity_controls %}
      <div class="actions">
        {% if product.variants.size > 1 %}
          {% if product.isTrackingInventory %}
            {% assign has_available_variant = false %}
            {% for variant in product.variants %}
              {% if variant.inventory > 0 %}
                {% assign has_available_variant = true %}
              {% endif %}
            {% endfor %}
          {% endif %}
          <a
            ui-slot="button"
            data-variant="secondary"
            data-size="lg"
            href="{{ product.url }}"
            {% unless product.isTrackingInventory == false or has_available_variant %}
              aria-disabled="true"
            {% endunless %}
          >
            <span ui-slot="button-front">
              {% if product.isTrackingInventory and has_available_variant == false %}
                {{ 'product.inventory_out_of_stock' | t }}
              {% else %}
                {{ 'general.choose_options' | t }}
              {% endif %}
            </span>
          </a>
        {% else %}
          {% if settings.show_quantity_controls %}
            {% render 'core.quantity', size: 'sm' %}
          {% endif %}
          {% if settings.enable_quick_add %}
            {% if product.id %}
              {% render 'core.shop-button', mode: 'secondary', icon: settings.quick_add_icon %}
            {% else %}
              <button ui-slot="button" data-variant="secondary" data-size="lg" aria-disabled="true" disabled>
                <span ui-slot="button-front">
                  {{ 'product.inventory_out_of_stock' | t }}
                </span>
              </button>
            {% endif %}
          {% endif %}
        {% endif %}
      </div>
    {% endif %}
  </div>
</li>
