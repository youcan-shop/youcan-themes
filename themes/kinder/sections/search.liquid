{{ 'section.search.css' | asset_url | stylesheet_tag }}

<div
  ui-section="search"
  style="
    --bg-color: {{ section.settings.bg_color.hex }};
    --fg-color: {{ section.settings.fg_color.hex }};
    --top-spacing: {{ section.settings.top_spacing }}px;
    --bottom-spacing: {{ section.settings.bottom_spacing }}px;
  "
>
  {% paginate search.products by 24 cod %}
    {% if items.size > 1 %}
      {% assign result = 'search.result.many' | t %}
    {% else %}
      {% assign result = 'search.result.one' | t %}
    {% endif %}

    {% assign found_for = 'search.found_for' | t %}
    {% assign result = result | append: ' ' | append: found_for %}
    {% assign message = total | append: ' ' | append: result | append: ' "' | append: terms | append: '"' %}

    {% assign search = 'search.title' | t %}
    {% assign breadcrumb = search | append: ': ' | append: message %}

    {% capture breadcrumb_items %}
    {{ 'navigation.home' | t }},/|
    {{ breadcrumb }}
    {% endcapture %}

    {% render 'misc.breadcrumb', items: breadcrumb_items %}

    <div ui-slot="head">
      <h1 class="heading">{{ 'search.title' | t }}</h1>
      <form action="/search" class="search">
        <fieldset ui-slot="input-wrapper" data-size="lg" role="group">
          <i ui-slot="input-icon" class="hgi hgi-stroke hgi-search-01"></i>
          <input
            ui-search="input"
            ui-slot="input"
            name="q"
            type="text"
            value="{{ terms | escape }}"
            placeholder="{{ 'search.placeholder' | t }}"
          >
          <button
            ui-slot="input-inline-button"
            type="button"
            aria-label="Clear"
            onclick="
              const input = document.querySelector('[ui-search=\'input\']');

              if (!input) return;

              input.value = '';
              input.focus();
            "
          >
            {% render 'misc.icon', name: 'hgi-cancel-01' %}
          </button>
        </fieldset>
      </form>
    </div>
    <div class="controller">
      <h4 class="result">
        {{ message }}
      </h4>
      <div class="sort">
        <label for="sort">{{ 'general.sort.label' | t }}</label>
        {% render 'misc.sort', url: previous_page %}
      </div>
    </div>
    {% if items.size > 0 %}
      <ul class="list" style="--nbr-columns-desktop: {{ section.settings.nbr_columns_desktop }};">
        {% for product in items %}
          {% render 'block.product', product: product %}
        {% endfor %}
      </ul>

      {% render 'misc.pagination', next_page_url: next_page, previous_page_url: previous_page, current: current, last: last, terms: terms %}

    {% else %}
      {% assign empty_content = 'search.empty.title' | t %}
      {% render 'misc.empty', heading: empty_content %}
    {% endif %}
  {% endpaginate %}
</div>

{% schema %}
{
  "label": "t:sections.search.label",
  "templates": ["search"],
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "t:common.headers.colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "t:common.colors.bg_color",
      "default": "#fef7ee"
    },
    {
      "type": "color",
      "id": "fg_color",
      "label": "t:common.colors.fg_color",
      "default": "#0E0E0E"
    },
    {
      "type": "header",
      "content": "t:common.headers.layout"
    },
    {
      "type": "range",
      "id": "nbr_columns_desktop",
      "label": "t:common.globals.number_per_column",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "header",
      "content": "t:common.headers.spacing"
    },
    {
      "type": "range",
      "id": "top_spacing",
      "label": "t:common.spacing.top_spacing",
      "min": 0,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "bottom_spacing",
      "label": "t:common.spacing.bottom_spacing",
      "min": 0,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 24
    }
  ]
}
{% endschema %}
