{{ 'section.featured-collection.css' | asset_url | stylesheet_tag }}

<div
  ui-section="featured-collection"
  style="
    --bg-color: {{ section.settings.bg_color.hex }};
    --fg-color: {{ section.settings.fg_color.hex }};
    --top-spacing: {{ section.settings.top_spacing }}px;
    --bottom-spacing: {{ section.settings.bottom_spacing }}px;
  "
>
  {% if section.settings.show_banner %}
    <div class="banner" data-banner-placement="{{ section.settings.banner_placement }}">
      <div ui-slot="head">
        <h1 class="heading">{{ section.settings.heading }}</h1>
        <p class="description">{{ section.settings.description }}</p>
      </div>
      {% if section.settings.button_label and section.settings.collection %}
        <a
          ui-slot="button"
          data-variant="primary"
          data-size="lg"
          href="/collections/{{ section.settings.collection.slug }}"
        >
          <span ui-slot="button-front">
            {{ section.settings.button_label }}
          </span>
        </a>
      {% endif %}
    </div>
  {% endif %}
  <div class="products">
    {% assign max_products = section.settings.max_products_to_show %}

    {% if section.settings.collection.id %}
      {% paginate collection.products by max_products id category_id: section.settings.collection.id %}
        <ul ui-block="products">
          {% for product in items %}
            {% render 'block.product', product: product %}
          {% endfor %}
        </ul>
      {% endpaginate %}
    {% else %}
      <ul ui-block="products">
        {% for product in (1..max_products) %}
          {% render 'block.product' %}
        {% endfor %}
      </ul>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "label": "t:sections.featured_collection.label",
  "templates": ["index"],
  "limit": 3,
  "max_blocks": 11,
  "settings": [
    {
      "type": "header",
      "content": "t:common.headers.colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "t:common.colors.bg_color",
      "default": "#fef7ee"
    },
    {
      "type": "color",
      "id": "fg_color",
      "label": "t:common.colors.fg_color",
      "default": "#0E0E0E"
    },
    {
      "type": "header",
      "content": "t:common.headers.general"
    },
    {
      "type": "category",
      "id": "collection",
      "label": "t:common.globals.collection"
    },
    {
      "type": "range",
      "id": "max_products_to_show",
      "label": "t:common.globals.max_products",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "header",
      "content": "t:sections.featured_collection.banner"
    },
    {
      "type": "checkbox",
      "id": "show_banner",
      "label": "t:sections.featured_collection.show_banner",
      "default": true
    },
    {
      "type": "select",
      "id": "banner_placement",
      "label": "t:sections.featured_collection.banner_placement.label",
      "options": [
        { "label": "t:sections.featured_collection.banner_placement.banner_first", "value": "first" },
        { "label": "t:sections.featured_collection.banner_placement.banner_second", "value": "second" }
      ],
      "default": "first"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "t:sections.featured_collection.banner_image"
    },
    {
      "type": "range",
      "id": "banner_image_opacity",
      "label": "t:sections.featured_collection.banner_image_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 10
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:common.header.heading",
      "default": "t:sections.featured_collection.default.heading"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:common.header.description",
      "default": "t:sections.featured_collection.default.description"
    },
    {
      "type": "text",
      "id": "label",
      "label": "t:common.button.label",
      "default": "t:sections.image_with_text.default.button"
    },
    {
      "type": "select",
      "id": "style",
      "options": [
        { "label": "t:common.button.style.options.primary", "value": "primary" },
        { "label": "t:common.button.style.options.secondary", "value": "secondary" }
      ],
      "label": "t:common.button.style.label",
      "default": "primary"
    },
    {
      "type": "header",
      "content": "t:common.headers.spacing"
    },
    {
      "type": "range",
      "id": "top_spacing",
      "label": "t:common.spacing.top_spacing",
      "min": 0,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "bottom_spacing",
      "label": "t:common.spacing.bottom_spacing",
      "min": 0,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ]
}
{% endschema %}
