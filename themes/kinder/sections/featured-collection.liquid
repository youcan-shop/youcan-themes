{{ 'section.featured-collection.css' | asset_url | stylesheet_tag }}

<div
  ui-section="featured-collection"
  style="
    --top-spacing: {{ section.settings.top_spacing }}px;
    --bottom-spacing: {{ section.settings.bottom_spacing }}px;
    {% if section.settings.override_global_colors %}
      --brand-lightness: {{ section.settings.main_color.lightness | divided_by: 100 }};
      --brand-chroma: {{ section.settings.main_color.chroma }};
      --brand-hue: {{ section.settings.main_color.oklch_hue }};
    {% endif %}
  "
  {% if section.settings.override_global_colors %}
    data-scoped-color
    data-intensity="{{ section.settings.color_intensity }}"
  {% endif %}
>
  <div ui-slot="head">
    <h4 class="subheading">{{ section.settings.subheading }}</h4>
    <h1 class="heading">{{ section.settings.heading }}</h1>
  </div>
  <div class="core-area">
    {% if section.settings.show_image %}
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'media' %}
            <div ui-block="content" {{ block.youcan_attributes }} data-image-ratio="{{ block.settings.image_ratio }}">
              <div class="media">
                {% if block.settings.block_image.src %}
                  <img
                    src="{{ block.settings.block_image.src }}"
                    alt="{{ block.settings.block_heading }}"
                    height="100%"
                    width="100%"
                    loading="lazy"
                  >
                {% else %}
                  {% render 'misc.image-fallback', icon_size: 100 %}
                {% endif %}
              </div>
              <div
                class="content"
                data-text-alignment="{{ block.settings.text_alignment }}"
                data-vertical-alignment="{{ block.settings.vertical_alignment }}"
              >
                <h4 class="subheading">{{ block.settings.block_subheading }}</h4>
                <h1 class="heading">{{ block.settings.block_heading }}</h1>
                <a
                  class="cta"
                  {% if block.settings.block_button_style == 'underline' %}
                    ui-slot="link-button"
                    data-underline="true"
                  {% else %}
                    ui-slot="button"
                    data-variant="primary"
                  {% endif %}
                  {% if block.settings.block_button_style == 'primary' %}
                    data-mode="filled"
                  {% elsif block.settings.block_button_style == 'secondary' %}
                    data-mode="lighter"
                  {% endif %}
                  data-size="lg"
                  href="{{ block.settings.block_button_link }}"
                >
                  {{ block.settings.block_button_label }}
                </a>
              </div>
            </div>
        {% endcase %}
      {% endfor %}
    {% endif %}
    {% assign max_products = section.settings.max_products_to_show %}
    {% if section.settings.collection.id %}
      {% paginate collection.products by max_products id category_id: section.settings.collection.id %}
        <ul ui-block="products" style="--nbr-columns-desktop: {{ section.settings.nbr_columns_desktop }};">
          {% for product in items %}
            {% render 'block.product', product: product %}
          {% endfor %}
        </ul>
      {% endpaginate %}
    {% else %}
      <ul
        ui-block="products"
        style="
          --nbr-columns-desktop: {{ section.settings.nbr_columns_desktop }};
          --nbr-columns-mobile: {{ section.settings.nbr_columns_mobile }};
        "
      >
        {% for product in (1..max_products) %}
          {% render 'block.product' %}
        {% endfor %}
      </ul>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "label": "t:sections.featured_collection.label",
  "templates": ["index"],
  "limit": 3,
  "max_blocks": 11,
  "settings": [
    {
      "type": "header",
      "content": "t:common.headers.colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "t:common.colors.bg_color",
      "default": "#fef7ee"
    },
    {
      "type": "color",
      "id": "fg_color",
      "label": "t:common.colors.fg_color",
      "default": "#0E0E0E"
    },
    {
      "type": "header",
      "content": "t:common.headers.general"
    },
    {
      "type": "category",
      "id": "collection",
      "label": "t:common.globals.collection"
    },
    {
      "type": "range",
      "id": "max_products_to_show",
      "label": "t:common.globals.max_products",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8
    },
    {
      "type": "header",
      "content": "t:sections.featured_collection.banner"
    },
    {
      "type": "checkbox",
      "id": "show_banner",
      "label": "t:sections.featured_collection.show_banner",
      "default": true
    },
    {
      "type": "select",
      "id": "banner_placement",
      "label": "t:sections.featured_collection.image_placement.label",
      "options": [
        { "label": "t:sections.featured_collection.image_placement.banner_first", "value": "first" },
        { "label": "t:sections.featured_collection.image_placement.banner_second", "value": "second" }
      ],
      "default": "first"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "t:sections.featured_collection.banner_image"
    },
    {
      "type": "range",
      "id": "banner_image_opacity",
      "label": "t:sections.featured_collection.banner_image_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 10
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:common.header.heading",
      "default": "t:sections.featured_collection.default.heading"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:common.header.description",
      "default": "t:sections.featured_collection.default.description"
    },
    {
      "type": "text",
      "id": "label",
      "label": "t:common.button.label",
      "default": "t:sections.image_with_text.default.button"
    },
    {
      "type": "select",
      "id": "style",
      "options": [
        { "label": "t:common.button.style.options.primary", "value": "primary" },
        { "label": "t:common.button.style.options.secondary", "value": "secondary" }
      ],
      "label": "t:common.button.style.label",
      "default": "primary"
    },
    {
      "type": "header",
      "content": "t:common.headers.spacing"
    },
    {
      "type": "range",
      "id": "top_spacing",
      "label": "t:common.spacing.top_spacing",
      "min": 0,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "bottom_spacing",
      "label": "t:common.spacing.bottom_spacing",
      "min": 0,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ]
}
{% endschema %}
