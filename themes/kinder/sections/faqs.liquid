{{ 'section.faqs.css' | asset_url | stylesheet_tag }}

<div
  ui-section="faqs"
  style="
    --bg-color: {{ section.settings.bg_color.hex }};
    --inner-bg-color: {{ section.settings.inner_bg_color.hex }};
    --fg-color: {{ section.settings.fg_color.hex }};
    --top-spacing: {{ section.settings.top_spacing }}px;
    --bottom-spacing: {{ section.settings.bottom_spacing }}px;
  "
>
  <div class="faqs-card">
    <div ui-slot="head">
      <h1 class="heading">{{ section.settings.heading }}</h1>
      <p class="description">{{ section.settings.description }}</p>
    </div>
    <ul class="items-area" ui-slot="accordion">
      {% for faq in section.blocks %}
        {% render 'block.faq' %}
      {% endfor %}
    </ul>
  </div>
</div>

{% schema %}
{
  "label": "t:sections.faqs.label",
  "templates": ["index", "product", "page", "cart"],
  "limit": 3,
  "max_blocks": 10,
  "settings": [
    {
      "type": "header",
      "content": "t:common.headers.colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "t:common.colors.bg_color",
      "default": "#fef7ee"
    },
    {
      "type": "color",
      "id": "inner_bg_color",
      "label": "t:sections.faqs.inner_bg_color",
      "default": "#FEFEFE"
    },
    {
      "type": "color",
      "id": "fg_color",
      "label": "t:common.colors.fg_color",
      "default": "#0E0E0E"
    },
    {
      "type": "header",
      "content": "t:common.headers.header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:common.header.heading",
      "default": "t:sections.faqs.default.heading"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:common.header.description",
      "default": "t:sections.faqs.default.description"
    },
    {
      "type": "header",
      "content": "t:common.headers.media"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:common.globals.image"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "t:common.globals.image_ratio",
      "options": [
        { "label": "t:common.layout.ratio.square", "value": "square" },
        { "label": "t:common.layout.ratio.portrait", "value": "portrait" },
        { "label": "t:common.layout.ratio.landscape", "value": "landscape" }
      ],
      "default": "portrait"
    },
    {
      "type": "select",
      "id": "image_placement",
      "label": "t:common.globals.image_placement",
      "options": [
        { "label": "t:common.layout.image_placement.image_first", "value": "first" },
        { "label": "t:common.layout.image_placement.image_second", "value": "second" }
      ],
      "default": "first"
    },
    {
      "type": "header",
      "content": "t:common.headers.spacing"
    },
    {
      "type": "range",
      "id": "top_spacing",
      "label": "t:common.spacing.top_spacing",
      "min": 0,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "bottom_spacing",
      "label": "t:common.spacing.bottom_spacing",
      "min": 0,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "label": "t:sections.faqs.blocks.faq.label",
      "settings": [
        {
          "type": "text",
          "id": "faq_title",
          "label": "t:sections.faqs.blocks.faq.title",
          "default": "t:sections.faqs.blocks.faq.default.title"
        },
        {
          "type": "textarea",
          "id": "faq_content",
          "label": "t:common.headers.content",
          "default": "t:sections.faqs.blocks.faq.default.content"
        },
        {
          "type": "checkbox",
          "id": "faq_open_by_default",
          "label": "t:sections.faqs.blocks.faq.open_by_default",
          "default": false
        }
      ]
    }
  ]
}
{% endschema %}
