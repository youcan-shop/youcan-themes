{{ 'section.thankyou.css' | asset_url | stylesheet_tag }}

<style>
  #youcan-section--{{ section.id }} {
    --bg-color: {{ section.settings.bg_color.hex }};
    --fg-color: {{ section.settings.fg_color.hex }};
    --top-spacing: {{ section.settings.top_spacing }}px;
    --bottom-spacing: {{ section.settings.bottom_spacing }}px;

    padding-inline: var(--spacing-16);
    background-color: var(--bg-color);
    color: var(--fg-color);
  }
</style>

<div ui-slot="container">
  <div ui-section="thankyou">
    <div class="content-area">
      <h1 class="heading">{{ 'order.title' | t }}</h1>
      <p class="description">{{ 'order.description' | t }}</p>
      <a
        ui-slot="button"
        data-variant="primary"
        data-mode="filled"
        data-size="lg"
        href="{{ routes.root_url |  default: "/" }}"
      >
        <span ui-slot="button-front">
          {{ 'order.action' | t }}
        </span>
      </a>
    </div>
    <div class="order-summary-area">
      <div class="statuses">
        <div class="item">
          <span ui-slot="label">{{ 'order.status.label' | t }}</span>
          {% render 'const.payment-status', status: order.paymentStatusSlug %}
        </div>
        <div class="item">
          <span ui-slot="label">{{ 'order.payment_method.label' | t }}:</span>
          <span class="value">
            {% assign payment_gateway = order.gatewayType %}
            {% render 'const.payment-gateway', type: payment_gateway %}
          </span>
        </div>
      </div>
      <div class="products">
        {% for product in order.order_variants %}
          <div class="product">
            <div class="media">
              {% if product.image %}
                <img
                  src="{{ product.image }}"
                  alt="{{ product.name }}"
                  height="100%"
                  width="100%"
                  loading="eager"
                >
              {% else %}
                {% render 'misc.image-fallback' %}
              {% endif %}
            </div>
            <div class="content">
              <a
                ui-slot="link-button"
                data-size="md"
                class="title"
                href="{{ product.url }}"
              >
                {{ product.name }}
              </a>
              <span class="count">x{{ product.quantity }}</span>
            </div>
            <span class="price">{{ product.price | default: 0 | money }}</span>
          </div>
          {% unless forloop.last %}
            <hr ui-slot="divider" data-variant="line">
          {% endunless %}
        {% endfor %}
      </div>
      <div class="summary">
        <div class="item">
          <span ui-slot="label">{{ 'order.subtotal' | t }}</span>
          <span class="value">{{ order.sub_total | default: 0 | money }}</span>
        </div>
        {% if order.coupon != null %}
          <div class="item">
            <span ui-slot="label">{{ 'order.coupon_code' | t }}</span>
            <div class="value">{{ order.coupon.code }}</div>
          </div>
          <div class="item">
            <span ui-slot="label">{{ 'order.discount_amount' | t }}</span>
            <span class="value">
              {% render 'const.discount-value', coupon: order.coupon %}
            </span>
          </div>
        {% endif %}
        {% if order.vat != 0 %}
          <div class="item">
            <span ui-slot="label">{{ 'cart.page.summary.vat' | t }} ({{ order.vat | times: 100 | append: '%' }})</span>
            <span class="value">{{ order.total_tax_amount | default: 0 | money }}</span>
          </div>
        {% endif %}
        <div class="item">
          <span ui-slot="label">{{ 'order.shipping' | t }}</span>
          {% if order.shippingCost == 0 or order.shippingCost == null %}
            {% assign shipping_cost = 'order.free' | t %}
          {% else %}
            {% assign shipping_cost = order.shippingCost | default: 0 | money %}
          {% endif %}
          <span class="value">{{ shipping_cost }}</span>
        </div>
        <hr ui-slot="divider" data-variant="line">
        <div class="item">
          <span ui-slot="label">{{ 'order.total' | t }}</span>
          <span class="value">{{ order.total | default: 0 | money }}</span>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "label": "t:sections.thankyou.label",
  "templates": ["thankyou"],
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "t:common.headers.colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "t:common.colors.bg_color",
      "default": "#fef7ee"
    },
    {
      "type": "color",
      "id": "fg_color",
      "label": "t:common.colors.fg_color",
      "default": "#0E0E0E"
    },
    {
      "type": "header",
      "content": "t:common.headers.spacing"
    },
    {
      "type": "range",
      "id": "top_spacing",
      "label": "t:common.spacing.top_spacing",
      "min": 0,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "bottom_spacing",
      "label": "t:common.spacing.bottom_spacing",
      "min": 0,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ]
}
{% endschema %}
