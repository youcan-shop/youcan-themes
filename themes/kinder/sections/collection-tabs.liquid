{{ 'section.collection-tabs.css' | asset_url | stylesheet_tag }}

<style>
  #youcan-section--collection-tabs {
    --bg-color: {{ section.settings.bg_color.hex }};
    --fg-color: {{ section.settings.fg_color.hex }};
    --top-spacing: {{ section.settings.top_spacing }}px;
    --bottom-spacing: {{ section.settings.bottom_spacing }}px;
  }
</style>

<div ui-slot="container">
  <ui-carousel
    ui-section="collection-tabs"
  >
    <div
      ui-slot="head"
      data-align="{{ section.settings.heading_alignment_desktop }}"
      data-align-mobile="{{ section.settings.heading_alignment_mobile }}"
    >
      <h1 class="heading">{{ section.settings.heading }}</h1>
      <p class="description">{{ section.settings.description }}</p>
    </div>
    <div class="content">
      <aside class="sidebar">
        <div class="media" data-image-ratio="{{ section.settings.image_ratio }}">
          {% if section.settings.image.src %}
            <img
              src="{{ section.settings.image.src }}"
              alt="FAQs"
              height="100%"
              width="100%"
              loading="lazy"
            >
          {% else %}
            {% render 'misc.image-fallback', icon_size: 100 %}
          {% endif %}
        </div>
        {% if section.blocks.size > 1 %}
          <div class="tab-list" role="tablist">
            {% for collection_block in section.blocks %}
              <button
                class="tab-trigger"
                ui-carousel="marker"
                {% if forloop.first %}
                  aria-selected="true"
                {% endif %}
                {{ collection_block.youcan_attributes }}
              >
                <span>
                  {% assign translated_trigger = 'collection-tabs.tab-trigger' | t %}
                  {% assign fallback = translated_trigger | append: ' ' | append: forloop.index %}
                  {{ collection_block.settings.tab_name | default: collection_block.settings.collection.name | default: fallback }}
                </span>

                {% render 'misc.icon', name: 'hgi-arrow-right-02', size: 24 %}
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </aside>
      <div class="products-area" ui-carousel="wrapper" ui-slot="carousel" aria-orientation="vertical">
        {% for collection_block in section.blocks %}
          {% assign max_products = section.settings.max_products_to_show %}
          {% if collection_block.settings.collection.id %}
            {% paginate collection.products by max_products id category_id: collection_block.settings.collection.id %}
              <div
                class="tab-content"
                ui-carousel="item"
                ui-slot="carousel-item"
                role="tabpanel"
                style="
                  --nbr-columns-desktop: {{ section.settings.nbr_columns_desktop }};
                  --nbr-columns-mobile: {{ section.settings.nbr_columns_mobile }};
                "
              >
                <div class="tab-head">
                  <h2 class="collection-name">{{ collection_block.settings.collection.name }}</h2>
                  {% if section.settings.show_view_all_button %}
                    <a
                      ui-slot="link-button"
                      data-size="md"
                      data-underline="true"
                      href="/collections/{{ collection_block.settings.collection.slug }}"
                    >
                      {{ 'collection-tabs.view_all' | t }}
                    </a>
                  {% endif %}
                </div>
                {% if items.size == 0 %}
                  <div class="empty-message">
                    <p>
                      {{ 'single-collection.empty.title' | t }}
                    </p>
                  </div>
                {% endif %}
                <ul class="items">
                  {% for product in items %}
                    {% render 'block.product-tab', product: product %}
                  {% endfor %}
                </ul>
              </div>
            {% endpaginate %}
          {% else %}
            <ul
              class="items"
              ui-carousel="item"
              ui-slot="carousel-item"
              role="tabpanel"
              style="
                --nbr-columns-desktop: {{ section.settings.nbr_columns_desktop }};
                --nbr-columns-mobile: {{ section.settings.nbr_columns_mobile }};
              "
            >
              {% for product in (1..max_products) %}
                {% render 'block.product-tab', product: product %}
              {% endfor %}
            </ul>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </ui-carousel>
</div>

{% schema %}
{
  "label": "t:sections.collection_tabs.label",
  "templates": ["index", "product", "page", "cart"],
  "limit": 2,
  "max_blocks": 4,
  "settings": [
    {
      "type": "header",
      "content": "t:common.headers.colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "t:common.colors.bg_color",
      "default": "#fef7ee"
    },
    {
      "type": "color",
      "id": "fg_color",
      "label": "t:common.colors.fg_color",
      "default": "#0E0E0E"
    },
    {
      "type": "header",
      "content": "t:common.headers.header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:common.header.heading",
      "default": "t:sections.collections.default.heading"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:common.header.description",
      "default": ""
    },
    {
      "type": "select",
      "id": "heading_alignment_desktop",
      "label": "t:common.globals.text_alignment",
      "options": [
        { "label": "t:common.layout.alignment.start", "value": "start" },
        { "label": "t:common.layout.alignment.center", "value": "center" },
        { "label": "t:common.layout.alignment.end", "value": "end" }
      ],
      "default": "start"
    },
    {
      "type": "select",
      "id": "heading_alignment_mobile",
      "label": "t:common.globals.text_alignment_mobile",
      "options": [
        { "label": "t:common.layout.alignment.inherit", "value": "inherit" },
        { "label": "t:common.layout.alignment.start", "value": "start" },
        { "label": "t:common.layout.alignment.center", "value": "center" },
        { "label": "t:common.layout.alignment.end", "value": "end" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "t:common.headers.layout"
    },
    {
      "type": "checkbox",
      "id": "show_view_all_button",
      "label": "t:sections.collection_tabs.show_view_all",
      "default": true
    },
    {
      "type": "range",
      "id": "max_products_to_show",
      "label": "t:common.globals.max_products",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 9
    },
    {
      "type": "range",
      "id": "nbr_columns_desktop",
      "label": "t:common.globals.number_per_column",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "header",
      "content": "t:common.headers.mobile_layout"
    },
    {
      "type": "select",
      "id": "nbr_columns_mobile",
      "label": "t:common.globals.number_per_column_mobile",
      "options": [
        { "label": "t:common.layout.column.one", "value": "1" },
        { "label": "t:common.layout.column.two", "value": "2" }
      ],
      "default": "2"
    },
    {
      "type": "header",
      "content": "t:sections.collection_tabs.sidebar"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:common.globals.image"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "t:common.globals.image_ratio",
      "options": [
        { "label": "t:common.layout.ratio.square", "value": "square" },
        { "label": "t:common.layout.ratio.portrait", "value": "portrait" },
        { "label": "t:common.layout.ratio.landscape", "value": "landscape" }
      ],
      "default": "landscape"
    },
    {
      "type": "header",
      "content": "t:common.headers.spacing"
    },
    {
      "type": "range",
      "id": "top_spacing",
      "label": "t:common.spacing.top_spacing",
      "min": 0,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "bottom_spacing",
      "label": "t:common.spacing.bottom_spacing",
      "min": 0,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "collection_item",
      "label": "t:sections.collection_tabs.blocks.tab.label",
      "settings": [
        {
          "type": "text",
          "id": "tab_name",
          "label": "t:sections.collection_tabs.tab_name"
        },
        {
          "type": "category",
          "id": "collection",
          "label": "t:common.globals.collection"
        }
      ]
    }
  ]
}
{% endschema %}
