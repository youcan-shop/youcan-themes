{{ 'section.image-banners.css' | asset_url | stylesheet_tag }}

<div
  ui-section="image-banners"
  role="banner"
  {% if section.settings.fullscreen %}
    data-fullscreen
  {% endif %}
  style="
    --bg-color: {{ section.settings.bg_color.hex }};
    --desktop-height: {{ section.settings.desktop_height }}px;
    --mobile-height: {{ section.settings.mobile_height }}px;
    --top-spacing: {{ section.settings.top_spacing }}px;
    --bottom-spacing: {{ section.settings.bottom_spacing }}px;
  "
>
  <ul class="banners">
    {% for item in section.blocks %}
      <li class="image-item" {{ item.youcan_attributes }}>
        <div ui-block="image">
          {% if item.settings.image %}
            <img
              src="{{ item.settings.image.src }}"
              alt="image-{{ forloop.index }}"
              height="100%"
              width="100%"
              loading="lazy"
            >
          {% else %}
            {% render 'misc.image-fallback', icon_size: 80 %}
          {% endif %}
        </div>
        <a
          ui-slot="button"
          ui-block="button"
          data-variant="primary"
          data-size="lg"
          {% if item.settings.button_link %}
            href="{{ item.settings.button_link }}"
          {% endif %}
        >
          <span ui-slot="button-front">
            {{ item.settings.button_label }}
          </span>
        </a>
      </li>
    {% endfor %}
  </ul>
</div>

{% schema %}
{
  "label": "t:sections.image_banners.label",
  "limit": 2,
  "max_blocks": 10,
  "settings": [
    {
      "type": "header",
      "content": "t:common.headers.colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "t:common.colors.bg_color",
      "default": "#fef7ee"
    },
    {
      "type": "header",
      "content": "t:common.headers.general"
    },
    {
      "type": "checkbox",
      "id": "fullscreen",
      "label": "t:common.marquee.fullscreen",
      "default": false
    },
    {
      "type": "header",
      "content": "t:sections.image_banners.grid"
    },
    {
      "type": "range",
      "id": "desktop_height",
      "label": "t:sections.image_banners.desktop_height",
      "min": 200,
      "max": 400,
      "step": 10,
      "unit": "px",
      "default": 320
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "t:sections.image_banners.mobile_height",
      "min": 150,
      "max": 300,
      "step": 10,
      "unit": "px",
      "default": 200
    },
    {
      "type": "header",
      "content": "t:common.headers.spacing"
    },
    {
      "type": "range",
      "id": "top_spacing",
      "label": "t:common.spacing.top_spacing",
      "min": 0,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "bottom_spacing",
      "label": "t:common.spacing.bottom_spacing",
      "min": 0,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "image_item",
      "label": "t:sections.image_banners.blocks.image.label",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:common.globals.image",
          "default": ""
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "t:common.button.label",
          "default": "t:sections.image_banners.default.button"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "t:common.button.link",
          "default": "#"
        }
      ]
    }
  ]
}
{% endschema %}
