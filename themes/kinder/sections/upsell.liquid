{{ 'section.upsell.css' | asset_url | stylesheet_tag }}
{{ 'section.upsell.js' | asset_url | script_tag_deferred }}

{% capture product_offers %}
{
  {% for product in upsell.products %}
    "{{ product.id }}": "{{ product.variants.0.id }}"
    {% unless forloop.last %},{% endunless %}
  {% endfor %}
}
{% endcapture %}

<ui-upsell
  id="{{ upsell.id }}"
  order-id="{{ order.id }}"
  product-offers="{{ product_offers | strip_newlines | strip | escape }}"
  style="
    --bg-color: {{ section.settings.bg_color.hex }};
    --fg-color: {{ section.settings.fg_color.hex }};
    --top-spacing: {{ section.settings.top_spacing }}px;
    --bottom-spacing: {{ section.settings.bottom_spacing }}px;
  "
>
  <div class="head">
    <h3 class="title">{{ 'upsell.offer_title' | t }}</h3>
    <div class="options">
      <button ui-slot="button" data-variant="secondary" data-size="lg" name="no">
        <span ui-slot="button-front">
          {{ upsell.actions.btn_no.title }}
        </span>
      </button>
      <button ui-slot="button" data-variant="primary" data-mode="filled" data-size="lg" name="yes">
        <span ui-slot="button-front">
          {{ upsell.actions.btn_yes.title }}
        </span>
      </button>
    </div>
  </div>
  {% if upsell.description %}
    <div class="description">
      {{ upsell.description }}
    </div>
  {% endif %}
  {% if upsell.footer %}
    <div class="footer">{{ upsell.footer }}</div>
  {% endif %}
</ui-upsell>

{% schema %}
{
  "label": "t:sections.upsell.label",
  "templates": ["upsell"],
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "t:common.headers.colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "t:common.colors.bg_color",
      "default": "#fef7ee"
    },
    {
      "type": "color",
      "id": "fg_color",
      "label": "t:common.colors.fg_color",
      "default": "#0E0E0E"
    },
    {
      "type": "header",
      "content": "t:common.headers.spacing"
    },
    {
      "type": "range",
      "id": "top_spacing",
      "label": "t:common.spacing.top_spacing",
      "min": 0,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "bottom_spacing",
      "label": "t:common.spacing.bottom_spacing",
      "min": 0,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ]
}
{% endschema %}
