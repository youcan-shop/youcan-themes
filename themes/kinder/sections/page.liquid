{{ 'section.page.css' | asset_url | stylesheet_tag }}

<div
  ui-section="page"
  style="
    --bg-color: {{ section.settings.bg_color.hex }};
    --fg-color: {{ section.settings.fg_color.hex }};
    --top-spacing: {{ section.settings.top_spacing }}px;
    --bottom-spacing: {{ section.settings.bottom_spacing }}px;
  "
>
  <div ui-slot="head">
    <h1 class="heading">
      {% if page.template == 'contact' %}
        {{ 'contact.title' | t }}
      {% else %}
        {{ page.name }}
      {% endif %}
    </h1>
  </div>
  {% if page.template == 'contact' %}
    {% form 'contact' %}
      {% if form.posted_successfully %}
        <div ui-slot="alert" data-variant="lighter" data-status="success" data-size="md">
          {% render 'misc.icon', name: 'hgi-checkmark-circle-02' %}
          <span>{{ 'contact.success_message' | t }}</span>
        </div>
      {% elsif form.errors %}
        <div ui-slot="alert" data-variant="lighter" data-status="error" data-size="md">
          {% render 'misc.icon', name: 'hgi-alert-02' %}
          <span>{{ 'contact.error_message' | t }}</span>
        </div>
        <ul class="errors">
          {% for error in form.errors %}
            {% assign message = error[1] %}
            <li>
              <span ui-slot="hint" aria-invalid="true">{{ message }}</span>
            </li>
          {% endfor %}
        </ul>
      {% endif %}
      <div class="fields">
        <fieldset>
          <label ui-slot="label" for="email">{{ 'contact.fields.email' | t }}</label>
          <input
            ui-slot="input"
            data-size="lg"
            id="email"
            name="email"
            type="email"
            placeholder="{{ 'contact.fields.email' | t }}"
            required
          >
        </fieldset>
        <fieldset>
          <label ui-slot="label" for="subject">{{ 'contact.fields.subject' | t }}</label>
          <input
            ui-slot="input"
            data-size="lg"
            id="subject"
            name="subject"
            type="text"
            placeholder="{{ 'contact.fields.subject' | t }}"
            required
          >
        </fieldset>
        <fieldset>
          <label ui-slot="label" for="message">{{ 'contact.fields.message' | t }}</label>
          <textarea
            ui-slot="textarea"
            type="text"
            id="message"
            name="message"
            minlength="5"
            rows="8"
            placeholder="{{ 'contact.fields.message' | t }}"
            required
          ></textarea>
        </fieldset>
      </div>
      <button type="submit" ui-slot="button" data-variant="primary" data-mode="filled" data-size="lg">
        <span ui-slot="button-front">
          {{ 'contact.action' | t }}
        </span>
      </button>
    {% endform %}
  {% else %}
    {{ page.content }}
  {% endif %}
</div>

{% schema %}
{
  "label": "t:sections.page.label",
  "templates": ["page"],
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "t:common.headers.colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "t:common.colors.bg_color",
      "default": "#fef7ee"
    },
    {
      "type": "color",
      "id": "fg_color",
      "label": "t:common.colors.fg_color",
      "default": "#0E0E0E"
    },
    {
      "type": "header",
      "content": "t:common.headers.spacing"
    },
    {
      "type": "range",
      "id": "top_spacing",
      "label": "t:common.spacing.top_spacing",
      "min": 0,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "bottom_spacing",
      "label": "t:common.spacing.bottom_spacing",
      "min": 0,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ]
}
{% endschema %}
