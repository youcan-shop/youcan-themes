{{ 'section.testimonials.css' | asset_url | stylesheet_tag }}

<ui-carousel
  ui-section="testimonials"
  style="
    --top-spacing: {{ section.settings.top_spacing }}px;
    --bottom-spacing: {{ section.settings.bottom_spacing }}px;
    --per-page: {{ section.settings.nbr_columns_desktop }};
    {% if section.settings.override_global_colors %}
      --brand-lightness: {{ section.settings.main_color.lightness | divided_by: 100 }};
      --brand-chroma: {{ section.settings.main_color.chroma }};
      --brand-hue: {{ section.settings.main_color.oklch_hue }};
    {% endif %}
  "
  {% if section.settings.override_global_colors %}
    data-scoped-color
    data-intensity="{{ section.settings.color_intensity }}"
  {% endif %}
>
  <div ui-slot="head">
    <div class="content">
      <h4 class="subheading">{{ section.settings.subheading }}</h4>
      <h1 class="heading">{{ section.settings.heading }}</h1>
    </div>
    {% assign min_items = section.settings.nbr_columns_desktop | plus: 0 %}
    {% if section.blocks.size > min_items %}
      <div class="actions">
        <button
          ui-carousel="arrow-previous"
          ui-slot="button"
          data-variant="primary"
          data-mode="stroke"
          data-size="lg"
          data-as-icon
          data-flip-icon-in-rtl
          aria-label="Previous"
        >
          {% render 'misc.icon', name: 'hgi-arrow-left-01' %}
        </button>
        <button
          ui-carousel="arrow-next"
          ui-slot="button"
          data-variant="primary"
          data-mode="stroke"
          data-size="lg"
          data-as-icon
          data-flip-icon-in-rtl
          aria-label="Next"
        >
          {% render 'misc.icon', name: 'hgi-arrow-right-01' %}
        </button>
      </div>
    {% endif %}
  </div>
  <ul class="items-area" ui-carousel="wrapper" ui-slot="carousel" aria-orientation="vertical" data-align="center">
    {% for testimonial in section.blocks %}
      {% render 'block.testimonial' %}
    {% endfor %}
  </ul>
</ui-carousel>

{% schema %}
{
  "label": "t:sections.testimonials.label",
  "templates": ["index", "page"],
  "limit": 3,
  "max_blocks": 10,
  "settings": [
    {
      "type": "header",
      "content": "t:common.headers.colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "t:common.colors.bg_color",
      "default": "#fef7ee"
    },
    {
      "type": "color",
      "id": "fg_color",
      "label": "t:common.colors.fg_color",
      "default": "#0E0E0E"
    },
    {
      "type": "header",
      "content": "t:common.headers.header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:common.header.heading",
      "default": "t:sections.testimonials.default.heading"
    },
    {
      "type": "text",
      "id": "description",
      "label": "t:common.header.description",
      "default": "t:sections.testimonials.default.description"
    },
    {
      "type": "header",
      "content": "t:common.headers.layout"
    },
    {
      "type": "range",
      "id": "nbr_columns_desktop",
      "label": "t:common.globals.number_per_column",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "header",
      "content": "t:common.headers.spacing"
    },
    {
      "type": "range",
      "id": "top_spacing",
      "label": "t:common.spacing.top_spacing",
      "min": 0,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "bottom_spacing",
      "label": "t:common.spacing.bottom_spacing",
      "min": 0,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "testimonial_item",
      "label": "t:sections.testimonials.blocks.testimonial.label",
      "settings": [
        {
          "type": "select",
          "id": "testimonial_rating",
          "label": "t:sections.testimonials.blocks.testimonial.rating.label",
          "options": [
            { "label": "⭐⭐⭐⭐⭐ (5)", "value": "5" },
            { "label": "⭐⭐⭐⭐ (4)", "value": "4" },
            { "label": "⭐⭐⭐ (3)", "value": "3" },
            { "label": "⭐⭐ (2)", "value": "2" },
            { "label": "⭐ (1)", "value": "1" }
          ],
          "default": "5"
        },
        {
          "type": "textarea",
          "id": "testimonial_content",
          "label": "t:common.headers.description",
          "default": "t:sections.testimonials.blocks.testimonial.description.default"
        },
        {
          "type": "text",
          "id": "testimonial_author",
          "label": "t:sections.testimonials.blocks.testimonial.author.label",
          "default": "t:sections.testimonials.blocks.testimonial.author.default"
        }
      ]
    }
  ]
}
{% endschema %}
