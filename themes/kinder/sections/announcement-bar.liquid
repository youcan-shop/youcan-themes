{{ 'section.announcement-bar.css' | asset_url | stylesheet_tag }}

<div
  ui-section="announcement-bar"
  role="banner"
>
  <ul>
    {% for item in section.blocks %}
      <li class="item">
        {% if item.settings.link %}
          <a ui-slot="link-button" data-size="md" href="{{ item.settings.link }}">
            {{ item.settings.text }}
          </a>
        {% else %}
          <span>
            {{ item.settings.text }}
          </span>
        {% endif %}
      </li>
    {% endfor %}
  </ul>
</div>

{% schema %}
{
  "label": "t:sections.announcement_bar.label",
  "tag": "header",
  "limit": 1,
  "max_blocks": 10,
  "settings": [
    {
      "type": "header",
      "content": "t:common.headers.colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "t:common.colors.bg_color",
      "default": "#E14A43"
    },
    {
      "type": "color",
      "id": "fg_color",
      "label": "t:common.colors.fg_color",
      "default": "#FAFAFA"
    },
    {
      "type": "header",
      "content": "t:common.headers.general"
    },
    {
      "type": "checkbox",
      "id": "homepage_only",
      "label": "t:sections.announcement_bar.homepage_only",
      "default": false
    },
    {
      "type": "header",
      "content": "t:common.headers.motion"
    },
    {
      "type": "range",
      "id": "change_every",
      "label": "t:sections.announcement_bar.speed",
      "min": 3,
      "max": 7,
      "step": 1,
      "unit": "s",
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "t:sections.announcement_bar.pause_on_hover",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "announcement_item",
      "label": "t:sections.announcement_bar.blocks.announcement.label",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "t:sections.announcement_bar.blocks.announcement.text",
          "default": "t:sections.announcement_bar.blocks.announcement.default"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.announcement_bar.blocks.announcement.link",
          "default": ""
        }
      ]
    }
  ]
}
{% endschema %}
