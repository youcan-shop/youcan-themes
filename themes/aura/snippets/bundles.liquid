      <div class="detail">
        <div class="box">
          <h3 class="title">{{ bundle.title }}</h3>
          <div class="price">
            <span class="original">{{ bundle.total_price | money }}</span>
            {% if bundle.compare_price %}
              <span class="compare-at">{{ bundle.compare_price | money }}</span>
            {% endif %}
          </div>
        </div>
        <div class="box">
          <span class="bundle-save-badge bundle-save-badge--stroke">x{{ bundle.bundle_products.size }}</span>
          {% if bundle.saving_percentage %}
            <span class="bundle-save-badge bundle-save-badge--success">
              {{ 'general.you_save' | t }}
              {{ bundle.saving_percentage }}%
            </span>
          {% endif %}
        </div>
      </div>
    </div>
    <ul class="list">
      {% for item in bundle.bundle_products %}
        {% assign p = item.selected_variant %}
        {% unless item.discount_value %}
          <div class="item">
            <div class="media">
              {% if p.image %}
                <img
                  src="https://cdn.youcan.shop/{{ p.image }}"
                  alt="{{ item.product.name }}"
                  width="65"
                  height="65"
                  loading="lazy"
                >
              {% elsif item.thumbnail %}
                <img src="{{ item.thumbnail }}" alt="{{ item.product.name }}" width="65" height="65" loading="lazy">
              {% endif %}
            </div>
            <div class="info">
              <span class="name">{{ item.product.name }}</span>
              <div class="price">
                <span class="original">{{ item.price | money }}</span>
              </div>
              {% unless p.variations == null or p.variations.default %}
                <div class="variants">
                  {% for variant in p.variations %}
                    <span class="variant">{{ variant[1] }}</span>
                  {% endfor %}
                </div>
              {% endunless %}
            </div>
          </div>
        {% endunless %}
      {% endfor %}
    </ul>
    <div class="gift">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 10 10" height="16" width="16">
        <path fill="currentColor" fill-rule="evenodd" d="M8.782 2.085a1.5 1.5 0 0 1 0.968 1.403v2.005l-4.257 0V2.001h-1v3.492H0.25V3.488a1.5 1.5 0 0 1 0.956 -1.399A1.98 1.98 0 0 1 1.45 0.94c0.286 -0.516 0.827 -0.938 1.515 -0.938 0.695 0 1.324 0.372 1.762 0.826 0.095 0.098 0.185 0.204 0.268 0.316A3.12 3.12 0 0 1 5.26 0.827C5.7 0.373 6.33 0 7.023 0c0.689 0 1.23 0.422 1.516 0.939 0.186 0.335 0.283 0.74 0.243 1.145Zm-6.58 -0.097h2.145a2.013 2.013 0 0 0 -0.34 -0.466C3.69 1.193 3.304 1 2.964 1c-0.25 0 -0.49 0.153 -0.641 0.424a0.967 0.967 0 0 0 -0.122 0.563Zm3.44 0c0.08 -0.155 0.193 -0.316 0.338 -0.466C6.298 1.193 6.684 1 7.023 1c0.25 0 0.491 0.153 0.642 0.424 0.098 0.178 0.14 0.376 0.121 0.563H5.641ZM0.25 8.499V6.493h4.243V10H1.75a1.5 1.5 0 0 1 -1.5 -1.5ZM5.493 10V6.493H9.75V8.5a1.5 1.5 0 0 1 -1.5 1.5z" clip-rule="evenodd" stroke-width="1"></path>
      </svg>
      <span>{{ 'general.you_get' | t }}</span>
    </div>
    <ul class="list">
      {% for item in bundle.bundle_products %}
        {% assign p = item.selected_variant %}
        {% if item.discount_value %}
          <div class="item">
            <div class="media">
              {% if p.image %}
                <img
                  src="https://cdn.youcan.shop/{{ p.image }}"
                  alt="{{ item.product.name }}"
                  width="65"
                  height="65"
                  loading="lazy"
                >
              {% elsif item.thumbnail %}
                <img src="{{ item.thumbnail }}" alt="{{ item.product.name }}" width="65" height="65" loading="lazy">
              {% endif %}
            </div>
            <div class="info">
              <span class="name">{{ item.product.name }}</span>
              <div class="price">
                <span class="compare-at">{{ p.price | default: 0 | money }}</span>
                <span class="bundle-free-badge">{{ 'general.free' | t }}</span>
              </div>
              {% unless p.variations == null or p.variations.default %}
                <div class="variants">
                  {% for variant in p.variations %}
                    <span class="variant">{{ variant[1] }}</span>
                  {% endfor %}
                </div>
              {% endunless %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </ul>
  </label>
{% endfor %}

{% assign has_express_checkout = false %}
{% for block in section.blocks %}
  {% if block.type == 'express_checkout' %}
    {% assign has_express_checkout = true %}
    {% assign express_settings = block.settings %}
  {% endif %}
{% endfor %}

{% if has_express_checkout %}
  {% render 'express-checkout', checkout: checkout, is_sticky: false, settings: express_settings, form_id: 'bundle-express-checkout-form' %}
{% else %}
  <div class="bundle-add-to-cart">
    <button class="yc-btn add-to-cart-button w-full" onclick="addBundleToCart('{{ snippetId }}')">
      <span class="spinner hidden" id="loading__bundle-cart"></span>
      <span>{{ 'general.add_bundle_to_cart' | t }}</span>
    </button>
  </div>
{% endif %}
