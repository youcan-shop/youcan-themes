{{ 'section.upsell.css' | asset_url | stylesheet_tag }}
{{ 'section.upsell.js' | asset_url | script_tag_deferred }}

{% if section.settings.custom_color %}
  {% style %}
    #youcan-section--{{ section.id }}:has([ui-section="upsell"]) {
      --brand-lightness: {{ section.settings.color.lightness | divided_by: 100 }};
      --brand-chroma: {{ section.settings.color.chroma }};
      --brand-hue: {{ section.settings.color.oklch_hue }};
    }
  {% endstyle %}
{% endif %}

{% capture product_offers %}
{
  {% for product in upsell.products %}
    "{{ product.id }}": "{{ product.variants.0.id }}"
    {% unless forloop.last %},{% endunless %}
  {% endfor %}
}
{% endcapture %}

<ui-upsell
  ui-section="upsell"
  id="{{ upsell.id }}"
  order-id="{{ order.id }}"
  product-offers="{{ product_offers | strip_newlines | strip | escape }}"
  {% if section.settings.custom_color %}
    data-custom-color
    data-theme="{{ section.settings.theme }}"
  {% endif %}
>
  <div class="head">
    <h3 class="title">{{ 'upsell.offer_title' | t }}</h3>
    <div class="options">
      <button ui-slot="button" data-mode="stroke" data-size="lg" name="no">
        {{ upsell.actions.btn_no.title }}
      </button>
      <button ui-slot="button" data-mode="3d" data-size="lg" name="yes">
        {{ upsell.actions.btn_yes.title }}
      </button>
    </div>
  </div>
  {% if upsell.description %}
    <div class="description">
      {{ upsell.description }}
    </div>
  {% endif %}
  {% if upsell.footer %}
    <div class="footer">{{ upsell.footer }}</div>
  {% endif %}
</ui-upsell>

{% schema %}
{
  "label": "t:sections.upsell.label",
  "templates": ["upsell"],
  "limit": 1,
  "settings": [
    { "type": "checkbox", "id": "custom_color", "label": "t:common.custom_color.label", "default": false },
    {
      "type": "color",
      "id": "color",
      "label": "t:common.custom_color.color",
      "default": "#121212",
      "visible_if": { "setting_id": "custom_color", "value": true }
    },
    {
      "type": "select",
      "id": "theme",
      "label": "t:common.custom_color.theme.label",
      "options": [
        { "label": "t:common.custom_color.theme.options.light", "value": "light" },
        { "label": "t:common.custom_color.theme.options.dark", "value": "dark" }
      ],
      "default": "light",
      "visible_if": { "setting_id": "custom_color", "value": true }
    }
  ]
}
{% endschema %}
