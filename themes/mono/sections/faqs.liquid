{{ 'section.faqs.css' | asset_url | stylesheet_tag }}

{% if section.settings.custom_color %}
  {% style %}
    #youcan-section--{{ section.id }}:has([ui-section="faqs"]) {
      --brand-lightness: {{ section.settings.color.lightness | divided_by: 100 }};
      --brand-chroma: {{ section.settings.color.chroma }};
      --brand-hue: {{ section.settings.color.oklch_hue }};
    }
  {% endstyle %}
{% endif %}

<div
  ui-section="faqs"
  {% if section.settings.custom_color %}
    data-custom-color
    data-theme="{{ section.settings.theme }}"
  {% endif %}
>
  {% if section.settings.heading %}
    <div class="head">
      <h2 class="title">{{ section.settings.heading }}</h2>
    </div>
  {% endif %}
  {% if section.blocks.size %}
    <div class="list" ui-slot="accordion">
      {% for block in section.blocks %}
        <div ui-slot="accordion-item" {{ block.youcan_attributes }}>
          <label ui-slot="accordion-trigger">
            {{ block.settings.title }}
            <input
              type="checkbox"
              name="faq"
              {% if block.settings.open_by_default %}
                checked
              {% endif %}
            >
          </label>
          <div ui-slot="accordion-content" role="region">
            <article>{{ block.settings.content }}</article>
          </div>
        </div>
      {% endfor %}
    </div>
  {% else %}
    {% render 'misc.empty', type: 'block' %}
  {% endif %}
</div>

{% schema %}
{
  "label": "t:sections.faqs.label",
  "limit": 1,
  "max_blocks": 12,
  "settings": [
    { "type": "header", "content": "t:common.headers.header" },
    { "type": "text", "id": "heading", "label": "t:common.header.heading", "default": "t:sections.faqs.default.heading" },
    { "type": "header", "content": "t:common.headers.appearance" },
    { "type": "checkbox", "id": "custom_color", "label": "t:common.custom_color.label", "default": false },
    {
      "type": "color",
      "id": "color",
      "label": "t:common.custom_color.color",
      "default": "#121212",
      "visible_if": { "setting_id": "custom_color", "value": true }
    },
    {
      "type": "select",
      "id": "theme",
      "label": "t:common.custom_color.theme.label",
      "options": [
        { "label": "t:common.custom_color.theme.options.light", "value": "light" },
        { "label": "t:common.custom_color.theme.options.dark", "value": "dark" }
      ],
      "default": "light",
      "visible_if": { "setting_id": "custom_color", "value": true }
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "label": "t:sections.faqs.blocks.faq.label",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:common.content.title",
          "default": "t:sections.faqs.blocks.faq.default.title"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "t:common.headers.content",
          "default": "t:sections.faqs.blocks.faq.default.description"
        },
        { "type": "checkbox", "id": "open_by_default", "label": "t:sections.faqs.blocks.faq.open_by_default" }
      ]
    }
  ]
}
{% endschema %}
