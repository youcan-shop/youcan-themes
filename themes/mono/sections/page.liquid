{{ 'section.page.css' | asset_url | stylesheet_tag }}

{% if section.settings.custom_color %}
  {% style %}
    #youcan-section--{{ section.id }}:has([ui-section="page"]) {
      --brand-lightness: {{ section.settings.color.lightness | divided_by: 100 }};
      --brand-chroma: {{ section.settings.color.chroma }};
      --brand-hue: {{ section.settings.color.oklch_hue }};
    }
  {% endstyle %}
{% endif %}

<div
  ui-section="page"
  {% if section.settings.custom_color %}
    data-custom-color
    data-theme="{{ section.settings.theme }}"
  {% endif %}
>
  <div class="head">
    <a
      ui-slot="button"
      data-mode="3d"
      data-size="md"
      data-as-icon
      data-flip-icon-in-rtl
      aria-label="Back to home"
      href="/"
    >
      {% render 'misc.icon', name: 'hgi-arrow-left-01' %}
    </a>
    <h2 class="title">
      {% if page.template == 'contact' %}
        {{ 'contact.title' | t }}
      {% else %}
        {{ page.name }}
      {% endif %}
    </h2>
  </div>
  <div class="core">
    {% if page.template == 'contact' %}
      {% form 'contact' %}
        {% if form.posted_successfully %}
          <div ui-slot="alert" data-variant="lighter" data-status="success" data-size="md">
            {% render 'misc.icon', name: 'hgi-checkmark-circle-02' %}
            <span>{{ 'contact.success_message' | t }}</span>
          </div>
        {% elsif form.errors %}
          <div ui-slot="alert" data-variant="lighter" data-status="error" data-size="md">
            {% render 'misc.icon', name: 'hgi-alert-02' %}
            <span>{{ 'contact.error_message' | t }}</span>
          </div>
          <ul class="errors">
            {% for error in form.errors %}
              {% assign message = error[1] %}
              <li>
                <span ui-slot="hint" aria-invalid="true">{{ message }}</span>
              </li>
            {% endfor %}
          </ul>
        {% endif %}
        <div class="fields">
          <fieldset>
            <label ui-slot="label" for="email">{{ 'contact.fields.email' | t }}</label>
            <input
              ui-slot="input"
              id="email"
              name="email"
              type="email"
              placeholder="{{ 'contact.fields.email' | t }}"
              required
            >
          </fieldset>
          <fieldset>
            <label ui-slot="label" for="subject">{{ 'contact.fields.subject' | t }}</label>
            <input
              ui-slot="input"
              data-size="lg"
              id="subject"
              name="subject"
              type="text"
              placeholder="{{ 'contact.fields.subject' | t }}"
              required
            >
          </fieldset>
          <fieldset>
            <label ui-slot="label" for="message">{{ 'contact.fields.message' | t }}</label>
            <textarea
              ui-slot="textarea"
              type="text"
              id="message"
              name="message"
              minlength="5"
              rows="8"
              placeholder="{{ 'contact.fields.message' | t }}"
              required
            ></textarea>
          </fieldset>
        </div>
        <button type="submit" ui-slot="button" data-variant="primary" data-mode="filled" data-size="md">
          {{ 'contact.action' | t }}
        </button>
      {% endform %}
    {% else %}
      {{ page.content }}
    {% endif %}
  </div>
</div>

{% schema %}
{
  "label": "t:sections.page.label",
  "settings": [
    { "type": "header", "content": "t:common.headers.appearance" },
    { "type": "checkbox", "id": "custom_color", "label": "t:common.custom_color.label", "default": false },
    {
      "type": "color",
      "id": "color",
      "label": "t:common.custom_color.color",
      "default": "#121212",
      "visible_if": { "setting_id": "custom_color", "value": true }
    },
    {
      "type": "select",
      "id": "theme",
      "label": "t:common.custom_color.theme.label",
      "options": [
        { "label": "t:common.custom_color.theme.options.light", "value": "light" },
        { "label": "t:common.custom_color.theme.options.dark", "value": "dark" }
      ],
      "default": "light",
      "visible_if": { "setting_id": "custom_color", "value": true }
    }
  ]
}
{% endschema %}
