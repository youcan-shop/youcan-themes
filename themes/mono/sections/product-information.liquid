{{ 'section.product-information.css' | asset_url | stylesheet_tag }}

{% if section.settings.custom_color %}
  {% style %}
    #youcan-section--{{ section.id }}:has([ui-section="product-information"]) {
      --brand-lightness: {{ section.settings.color.lightness | divided_by: 100 }};
      --brand-chroma: {{ section.settings.color.chroma }};
      --brand-hue: {{ section.settings.color.oklch_hue }};
    }
  {% endstyle %}
{% endif %}

{% assign default_variant = product.selected_or_first_available_variant %}
{% assign price = default_variant.price | default: product.price %}
{% assign compare_at_price = default_variant.compare_at_price | default: product.compare_at_price %}

<ui-product
  ui-section="product-information"
  product-id="{{ product.id }}"
  {% if section.settings.custom_color %}
    data-custom-color
    data-theme="{{ section.settings.theme }}"
  {% endif %}
>
  <ui-carousel class="media" ui-product="media">
    <div class="list" ui-carousel="wrapper" ui-slot="carousel" aria-orientation="vertical">
      {% if product.images.size %}
        {% for image in product.images %}
          <div class="image-item" ui-carousel="item" ui-slot="carousel-item">
            <img
              src="{{ image }}"
              alt="{{ product.name }}"
              height="100%"
              width="100%"
              {% if forloop.index0 %}
                loading="eager"
              {% else %}
                loading="lazy"
              {% endif %}
            >
          </div>
        {% endfor %}
      {% else %}
        {% render 'misc.image-fallback', type: 'product', icon_size: 40 %}
      {% endif %}
    </div>
    {% if product.images.size > 1 %}
      <div
        class="markers"
        {% if product.images.size < 5 %}
          data-center="true"
        {% endif %}
        ui-slot="carousel"
        aria-orientation="vertical"
      >
        {% for marker in product.images %}
          <button
            class="marker"
            ui-carousel="marker"
            ui-slot="carousel-item"
            {% if forloop.first %}
              aria-selected="true"
            {% endif %}
          >
            <img
              src="{{ marker }}"
              alt="{{ product.name }}"
              height="100%"
              width="100%"
              loading="eager"
            >
          </button>
        {% endfor %}
      </div>
    {% endif %}
  </ui-carousel>
  <div class="core">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li>
          <a href="/">{{ 'product_information.navigation.home' | t }}</a>
        </li>
        <li>
          <span class="separator">•</span>
        </li>
        {% if product.categories %}
          <li>
            <a href="/collections/{{ product.categories[0].slug }}">
              {{ product.categories[0].name }}
            </a>
          </li>
        {% else %}
          <li>
            <a href="/collections">{{ 'product_information.navigation.collections' | t }}</a>
          </li>
        {% endif %}
        <li>
          <span class="separator">•</span>
        </li>
        <li>
          <span>{{ product.name }}</span>
        </li>
      </ol>
    </nav>
    <div class="bio">
      <h2 class="title">{{ product.name }}</h2>
      <div class="rating">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
        >
          <path d="M11.9961 1.25C13.0454 1.25 13.8719 2.04253 14.3995 3.11191L16.1616 6.66516C16.215 6.77513 16.3417 6.92998 16.5321 7.07164C16.7223 7.21315 16.9086 7.29121 17.0311 7.3118L20.2207 7.84613C21.3729 8.03973 22.3386 8.60449 22.6521 9.5879C22.9653 10.5705 22.5064 11.5916 21.6778 12.4216L21.677 12.4225L19.1991 14.9209C19.1009 15.0199 18.9909 15.2064 18.9219 15.4494C18.8534 15.6908 18.8473 15.9107 18.8784 16.0527L18.8788 16.0547L19.5877 19.1454C19.8818 20.4317 19.7843 21.7073 18.8771 22.3742C17.9667 23.0433 16.7227 22.7467 15.5925 22.0736L12.6026 20.289C12.477 20.214 12.2614 20.1532 12.0011 20.1532C11.7427 20.1532 11.5226 20.2132 11.3888 20.291L11.3869 20.2921L8.40288 22.0732C7.27405 22.7487 6.03154 23.04 5.12111 22.3702C4.21449 21.7032 4.11214 20.43 4.40711 19.1447L5.1159 16.0547L5.11633 16.0527C5.14741 15.9107 5.14133 15.6908 5.0728 15.4494C5.0038 15.2064 4.89379 15.0199 4.79558 14.9209L2.31585 12.4206C1.49265 11.5906 1.03521 10.5704 1.34595 9.58925C1.65759 8.60525 2.62143 8.0398 3.77433 7.84606L6.96132 7.31219L6.96233 7.31202C7.07917 7.29175 7.2627 7.21456 7.45248 7.07268C7.64261 6.93054 7.76959 6.77535 7.82312 6.66516L7.82582 6.65967L9.58562 3.11097L9.58632 3.10957C10.119 2.04108 10.948 1.25 11.9961 1.25Z" fill="currentColor"></path>
        </svg>
        {{ product.averageRating }}
      </div>
      <div class="price">
        <span class="price" ui-product-item="price">{{ price | money }}</span>
        {% if compare_at_price %}
          <span class="compare-at" ui-product-item="compare-at-price">{{ compare_at_price | money }}</span>
        {% endif %}
      </div>
    </div>
    {% if section.blocks.size %}
      {% for block in section.blocks %}
        {% if block.type == 'inventory-counter' and product.isTrackingInventory %}
          {% render 'misc.inventory-counter', count: default_variant.inventory, threshold: block.settings.inventory_threshold %}
        {% endif %}
      {% endfor %}
    {% endif %}
    {% if product.description %}
      <div class="field">
        <span class="title">{{ 'product_information.details' | t }}</span>
        <article>{{ product.description }}</article>
      </div>
    {% endif %}
    {% if product.options.size > 0 %}
      <div class="field">
        <span class="title">{{ 'product_information.variants' | t }}</span>
        {% render 'core.variants' %}
      </div>
    {% endif %}
    {% if section.blocks.size %}
      {% for block in section.blocks %}
        {% if block.type == 'add-ons' %}
          {% render 'misc.add-ons' %}
        {% endif %}
      {% endfor %}
    {% endif %}
    {% if settings.shopping_flow == 'express_checkout' and settings.form_style == 'inline' %}
      {% render 'core.express-checkout', product: product %}
    {% endif %}
    {% unless settings.shopping_flow == 'express_checkout' and settings.form_style == 'inline' %}
      <div class="shop-bar">
        <div class="bar-wrapper">
          <div class="bundle-selected" ui-slot="status-badge" data-variant="stroke" data-status="completed" hidden>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" height="16" width="16">
              <path fill-rule="evenodd" d="M1.5 8c0 -3.59 2.91 -6.5 6.5 -6.5s6.5 2.91 6.5 6.5 -2.91 6.5 -6.5 6.5S1.5 11.59 1.5 8Zm8.906666666666666 -1.2093333333333334a0.5 0.5 0 1 0 -0.8133333333333332 -0.5813333333333333l-2.1573333333333333 3.02L6.353333333333333 8.146666666666667a0.5 0.5 0 0 0 -0.7066666666666667 0.7066666666666667l1.5 1.5a0.5 0.5 0 0 0 0.7599999999999999 -0.06266666666666666l2.5 -3.5Z" clip-rule="evenodd" stroke-width="0.6667"></path>
            </svg>
            {{ 'general.selected_bundle' | t }}
          </div>
          {% render 'core.quantity', variant: '3d', size: 'md' %}
          {% case settings.shopping_flow %}
            {% when 'cart' %}
              {% render 'core.shop-button', product: product, size: 'lg' %}
            {% when 'express_checkout' %}
              {% if settings.form_style == 'drawer' %}
                <button ui-slot="button" data-mode="filled" data-size="lg" type="button" popovertarget="express-checkout-{{ product.id }}">
                  {{ 'general.buy_it_now' | t }}
                </button>
              {% endif %}
            {% when 'both' %}
              <div class="actions">
                {% render 'core.shop-button', skip_to_checkout: true, product: product, mode: '3d', size: 'lg' %}
                {% render 'core.shop-button', product: product, size: 'lg' %}
              </div>
          {% endcase %}
        </div>
      </div>
    {% endunless %}
    {% if product.is_bundle %}
      {% render 'core.bundles' %}
    {% endif %}
  </div>

  {% if settings.shopping_flow == 'express_checkout' and settings.form_style == 'drawer' %}
    {% render 'core.express-checkout', product: product, style: 'open-drawer' %}
  {% endif %}
</ui-product>

{% if product and product.options.size %}
  {% javascript %}
    if (!window.productsVariants["{{ product.id }}"]) {
      window.productsVariants["{{ product.id }}"] = JSON.parse({{ product.variants | json }});
    }
  {% endjavascript %}
{% endif %}

{% schema %}
{
  "label": "t:sections.product_information.label",
  "templates": ["product"],
  "limit": 1,
  "settings": [
    { "type": "header", "content": "t:common.headers.appearance" },
    { "type": "checkbox", "id": "custom_color", "label": "t:common.custom_color.label", "default": false },
    {
      "type": "color",
      "id": "color",
      "label": "t:common.custom_color.color",
      "default": "#121212",
      "visible_if": { "setting_id": "custom_color", "value": true }
    },
    {
      "type": "select",
      "id": "theme",
      "label": "t:common.custom_color.theme.label",
      "options": [
        { "label": "t:common.custom_color.theme.options.light", "value": "light" },
        { "label": "t:common.custom_color.theme.options.dark", "value": "dark" }
      ],
      "default": "light",
      "visible_if": { "setting_id": "custom_color", "value": true }
    }
  ],
  "blocks": [
    {
      "type": "inventory-counter",
      "label": "t:sections.product_information.blocks.inventory_counter.label",
      "limit": 1,
      "settings": [
        {
          "type": "range",
          "id": "inventory_threshold",
          "label": "t:common.inventory.threshold",
          "step": 1,
          "min": 2,
          "max": 100,
          "default": 10
        }
      ]
    },
    {
      "type": "add-ons",
      "label": "t:sections.product_information.blocks.add_ons.label",
      "limit": 1,
      "settings": [
        { "type": "paragraph", "content": "t:sections.product_information.blocks.add_ons.hint" },
        { "type": "header", "content": "t:common.headers.header" },
        {
          "type": "text",
          "id": "heading",
          "label": "t:common.header.heading",
          "default": "t:sections.product_information.blocks.add_ons.default.heading"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "t:common.header.description",
          "default": "t:sections.product_information.blocks.add_ons.default.description"
        },
        { "type": "header", "content": "t:common.headers.appearance" },
        {
          "type": "select",
          "id": "style",
          "label": "t:sections.product_information.blocks.add_ons.style.label",
          "options": [
            { "label": "t:sections.product_information.blocks.add_ons.style.options.grid", "value": "grid" },
            { "label": "t:sections.product_information.blocks.add_ons.style.options.list", "value": "list" },
            { "label": "t:sections.product_information.blocks.add_ons.style.options.slider", "value": "slider" }
          ],
          "default": "slider"
        }
      ]
    }
  ]
}
{% endschema %}
