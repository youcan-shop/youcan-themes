      {% when 'phone' %}
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
        >
          <path d="M9.09135 5.05591L8.83809 4.48608C8.49696 3.71854 8.3264 3.33477 8.0457 3.06351C7.86041 2.88445 7.64237 2.74275 7.40349 2.64615C7.0416 2.49982 6.62164 2.49982 5.7817 2.49982C4.53105 2.49982 3.90572 2.49982 3.4185 2.80345C3.11968 2.98967 2.83388 3.30583 2.67866 3.62188C2.42559 4.13717 2.483 4.70489 2.59781 5.84033C3.55055 15.2621 8.73782 20.4494 18.1596 21.4021C19.2951 21.517 19.8628 21.5744 20.3781 21.3213C20.6941 21.1661 21.0103 20.8803 21.1965 20.5815C21.5001 20.0942 21.5001 19.4689 21.5001 18.2183C21.5001 17.3783 21.5001 16.9584 21.3538 16.5965C21.2572 16.3576 21.1155 16.1395 20.9364 15.9543C20.6652 15.6736 20.2814 15.503 19.5139 15.1619L18.944 14.9086C18.2715 14.6097 17.9352 14.4602 17.5979 14.4318C17.2391 14.4016 16.8788 14.4686 16.5547 14.6255C16.2501 14.7731 15.9899 15.0333 15.4694 15.5538C14.9574 16.0658 14.7014 16.3218 14.3681 16.4725C14.0436 16.6192 13.5877 16.6816 13.2358 16.6274C12.8742 16.5717 12.6084 16.4218 12.0768 16.1219C10.1924 15.0591 8.94088 13.8076 7.87801 11.9231C7.57819 11.3916 7.42828 11.1258 7.37258 10.7641C7.31839 10.4123 7.38074 9.95632 7.52744 9.6319C7.6782 9.29851 7.9342 9.04251 8.44619 8.53052C8.96661 8.0101 9.22681 7.7499 9.37441 7.44525C9.5314 7.12119 9.59831 6.76086 9.5681 6.40205C9.53971 6.06473 9.39026 5.72845 9.09135 5.05591Z" fill="currentColor"></path>
