  </div>
  <div class="info">
    {% if section.settings.title %}
      <h2 class="heading">{{ section.settings.title }}</h2>
    {% endif %}
    {% if section.settings.description %}
      <p class="description">{{ section.settings.description }}</p>
    {% endif %}
  </div>
  {% if section.settings.show_arrow %}
    {% render 'misc.icon', name: 'hgi-arrow-right-02', size: 24 %}
  {% endif %}
</a>

{% schema %}
{
  "label": "t:sections.link.label",
  "settings": [
    { "type": "header", "content": "t:common.headers.content" },
    {
      "type": "text",
      "id": "title",
      "label": "t:common.content.title",
      "default": "t:sections.link.default.title"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:common.content.description",
      "default": "t:sections.link.default.description"
    },
    {
      "type": "url",
      "id": "url",
      "label": "t:common.link.url",
      "default": "https://youcan.shop"
    },
    {
      "type": "select",
      "id": "url_target",
      "label": "t:common.link.open_link_in.label",
      "options": [
        { "label": "t:common.link.open_link_in.options.same_tab", "value": "_self" },
        { "label": "t:common.link.open_link_in.options.new_tab", "value": "_blank" }
      ],
      "default": "_self"
    },
    { "type": "header", "content": "t:common.headers.media" },
    {
      "type": "select",
      "id": "icon",
      "label": "t:common.media.icon",
      "options": [
        { "label": "t:globals.social_media.youcan", "value": "youcan" },
        { "label": "t:globals.social_media.instagram", "value": "instagram" },
        { "label": "t:globals.social_media.facebook", "value": "facebook" },
        { "label": "t:globals.social_media.x_twitter", "value": "x_twitter" },
        { "label": "t:globals.social_media.whatsapp", "value": "whatsapp" },
        { "label": "t:globals.social_media.tiktok", "value": "tiktok" },
        { "label": "t:globals.social_media.snapchat", "value": "snapchat" },
        { "label": "t:globals.social_media.youtube", "value": "youtube" },
        { "label": "t:globals.social_media.linkedin", "value": "linkedin" },
        { "label": "t:globals.social_media.messenger", "value": "messenger" },
        { "label": "t:globals.social_media.email", "value": "email" },
        { "label": "t:globals.social_media.phone", "value": "phone" }
      ],
      "default": "youcan"
    },
    {
      "type": "checkbox",
      "id": "show_arrow",
      "label": "t:sections.link.show_arrow",
      "default": true
    },
    { "type": "header", "content": "t:common.headers.appearance" },
    { "type": "checkbox", "id": "custom_color", "label": "t:common.custom_color.label", "default": false },
    {
      "type": "color",
      "id": "color",
      "label": "t:common.custom_color.color",
      "default": "#121212",
      "visible_if": { "setting_id": "custom_color", "value": true }
    },
    {
      "type": "select",
      "id": "theme",
      "label": "t:common.custom_color.theme.label",
      "options": [
        { "label": "t:common.custom_color.theme.options.light", "value": "light" },
        { "label": "t:common.custom_color.theme.options.dark", "value": "dark" }
      ],
      "default": "light",
      "visible_if": { "setting_id": "custom_color", "value": true }
    }
  ]
}
{% endschema %}
