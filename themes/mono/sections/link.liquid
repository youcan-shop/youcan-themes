          <path fill="currentColor" fill-rule="evenodd" d="M1.25 11.267C1.25 5.574 6.086 1 12 1s10.75 4.574 10.75 10.267S17.914 21.535 12 21.535a11.2 11.2 0 0 1-2.91-.381l-2.06 1.548c-.974.732-2.363.036-2.363-1.18v-2.747c-2.099-1.87-3.417-4.54-3.417-7.508m5.5 2.858l2.828-1.414a1 1 0 0 1 .853-.02l3.25 1.445a1 1 0 0 0 1.27-.41l2.626-4.501a.25.25 0 0 0-.328-.35l-2.827 1.414a1 1 0 0 1-.853.02l-3.25-1.445a1 1 0 0 0-1.27.41l-2.626 4.501a.25.25 0 0 0 .328.35Z" clip-rule="evenodd"/>
        </svg>
      {% when 'email' %}
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
        >
          <path fill-rule="evenodd" clip-rule="evenodd" d="M14.92 2.78681C12.967 2.73773 11.033 2.73773 9.07999 2.7868L9.02182 2.78826C7.497 2.82655 6.27002 2.85735 5.2867 3.0286C4.2572 3.20789 3.42048 3.55177 2.71362 4.26132C2.00971 4.9679 1.66764 5.7926 1.49176 6.8054C1.32429 7.76978 1.29878 8.9668 1.26719 10.4496L1.26593 10.5084C1.24469 11.5047 1.24469 12.4953 1.26594 13.4916L1.26719 13.5504C1.29879 15.0332 1.32429 16.2302 1.49176 17.1946C1.66764 18.2074 2.00972 19.0321 2.71362 19.7387C3.42048 20.4482 4.2572 20.7921 5.2867 20.9714C6.27001 21.1426 7.49697 21.1735 9.02177 21.2117L9.07999 21.2132C11.033 21.2623 12.967 21.2623 14.92 21.2132L14.9782 21.2117C16.503 21.1735 17.73 21.1426 18.7133 20.9714C19.7428 20.7921 20.5795 20.4482 21.2864 19.7387C21.9903 19.0321 22.3324 18.2074 22.5082 17.1946C22.6757 16.2302 22.7012 15.0332 22.7328 13.5503L22.7341 13.4916C22.7553 12.4953 22.7553 11.5047 22.7341 10.5084L22.7328 10.4497C22.7012 8.96683 22.6757 7.76979 22.5082 6.80542C22.3324 5.79261 21.9903 4.96792 21.2864 4.26134C20.5795 3.55179 19.7428 3.20791 18.7133 3.02862C17.73 2.85737 16.503 2.82656 14.9782 2.78827L14.92 2.78681ZM7.38182 7.85452C7.02527 7.64371 6.56533 7.76186 6.35452 8.11841C6.14371 8.47497 6.26186 8.93491 6.61841 9.14572L9.56043 10.8851C10.4313 11.4 11.1827 11.7501 12.0001 11.7501C12.8175 11.7501 13.569 11.4 14.4398 10.8851L17.3818 9.14572C17.7384 8.93491 17.8565 8.47497 17.6457 8.11841C17.4349 7.76186 16.975 7.64371 16.6184 7.85452L13.6764 9.59395C12.832 10.0932 12.3831 10.2501 12.0001 10.2501C11.6171 10.2501 11.1682 10.0932 10.3238 9.59395L7.38182 7.85452Z" fill="currentColor"></path>
