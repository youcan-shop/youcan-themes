{{ 'section.testimonials.css' | asset_url | stylesheet_tag }}

{% if section.settings.custom_color %}
  {% style %}
    #youcan-section--{{ section.id }}:has([ui-section="testimonials"]) {
      --brand-lightness: {{ section.settings.color.lightness | divided_by: 100 }};
      --brand-chroma: {{ section.settings.color.chroma }};
      --brand-hue: {{ section.settings.color.oklch_hue }};
    }
  {% endstyle %}
{% endif %}

<ui-carousel
  ui-section="testimonials"
  {% if section.settings.custom_color %}
    data-custom-color
    data-theme="{{ section.settings.theme }}"
  {% endif %}
>
  {% if section.settings.heading %}
    <div class="head">
      <h2 class="title">{{ section.settings.heading }}</h2>
      {% if section.blocks.size > 1 and section.settings.arrows %}
        <div class="arrows">
          <button
            ui-carousel="arrow-previous"
            ui-slot="button"
            data-mode="stroke"
            data-size="xs"
            data-as-icon
            data-flip-icon-in-rtl
            aria-label="Previous"
          >
            {% render 'misc.icon', name: 'hgi-arrow-left-01' %}
          </button>
          <button
            ui-carousel="arrow-next"
            ui-slot="button"
            data-mode="stroke"
            data-size="xs"
            data-as-icon
            data-flip-icon-in-rtl
            aria-label="Next"
          >
            {% render 'misc.icon', name: 'hgi-arrow-right-01' %}
          </button>
        </div>
      {% endif %}
    </div>
  {% endif %}
  {% if section.blocks.size %}
    <ul class="list" ui-carousel="wrapper" ui-slot="carousel" aria-orientation="vertical">
      {% for block in section.blocks %}
        <li class="testimonial-item" ui-carousel="item" ui-slot="carousel-item" {{ block.youcan_attributes }}>
          <div class="info">
            <div class="stars">
              {% for star in (1..5) %}
                {% if star <= block.settings.rating %}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                  >
                    <path
                      d="M11.9961 1.25C13.0454 1.25 13.8719 2.04253 14.3995 3.11191L16.1616 6.66516C16.215 6.77513 16.3417 6.92998 16.5321 7.07164C16.7223 7.21315 16.9086 7.29121 17.0311 7.3118L20.2207 7.84613C21.3729 8.03973 22.3386 8.60449 22.6521 9.5879C22.9653 10.5705 22.5064 11.5916 21.6778 12.4216L21.677 12.4225L19.1991 14.9209C19.1009 15.0199 18.9909 15.2064 18.9219 15.4494C18.8534 15.6908 18.8473 15.9107 18.8784 16.0527L18.8788 16.0547L19.5877 19.1454C19.8818 20.4317 19.7843 21.7073 18.8771 22.3742C17.9667 23.0433 16.7227 22.7467 15.5925 22.0736L12.6026 20.289C12.477 20.214 12.2614 20.1532 12.0011 20.1532C11.7427 20.1532 11.5226 20.2132 11.3888 20.291L11.3869 20.2921L8.40288 22.0732C7.27405 22.7487 6.03154 23.04 5.12111 22.3702C4.21449 21.7032 4.11214 20.43 4.40711 19.1447L5.1159 16.0547L5.11633 16.0527C5.14741 15.9107 5.14133 15.6908 5.0728 15.4494C5.0038 15.2064 4.89379 15.0199 4.79558 14.9209L2.31585 12.4206C1.49265 11.5906 1.03521 10.5704 1.34595 9.58925C1.65759 8.60525 2.62143 8.0398 3.77433 7.84606L6.96132 7.31219L6.96233 7.31202C7.07917 7.29175 7.2627 7.21456 7.45248 7.07268C7.64261 6.93054 7.76959 6.77535 7.82312 6.66516L7.82582 6.65967L9.58562 3.11097L9.58632 3.10957C10.119 2.04108 10.948 1.25 11.9961 1.25Z"
                      fill="currentColor"></path>
                  </svg>
                {% else %}
                  {% render 'misc.icon', name: 'hgi-star' %}
                {% endif %}
              {% endfor %}
            </div>
            {% if block.settings.content_type == 'text' %}
              <article class="content">{{ block.settings.content }}</article>
            {% else %}
              <div class="media">
                {% if block.settings.image %}
                  <img
                    src="{{ block.settings.image.src }}"
                    alt="{{ block.settings.image_alt | default: 'Testimonial ' | append: forloop.index }}"
                    height="100%"
                    width="100%"
                    loading="lazy"
                  >
                {% else %}
                  {% render 'misc.image-fallback', icon_size: 40 %}
                {% endif %}
              </div>
            {% endif %}
          </div>
          <span class="author">{{ block.settings.author | default: 'Anonymous' }}</span>
        </li>
      {% endfor %}
    </ul>
  {% else %}
    {% render 'misc.empty', type: 'block' %}
  {% endif %}
</ui-carousel>

{% schema %}
{
  "label": "t:sections.testimonials.label",
  "limit": 3,
  "max_blocks": 12,
  "settings": [
    { "type": "header", "content": "t:common.headers.header" },
    {
      "type": "text",
      "id": "heading",
      "label": "t:common.header.heading",
      "default": "t:sections.testimonials.default.heading"
    },
    { "type": "checkbox", "id": "arrows", "label": "t:common.header.show_arrows", "default": true },
    { "type": "header", "content": "t:common.headers.appearance" },
    { "type": "checkbox", "id": "custom_color", "label": "t:common.custom_color.label", "default": false },
    {
      "type": "color",
      "id": "color",
      "label": "t:common.custom_color.color",
      "default": "#121212",
      "visible_if": { "setting_id": "custom_color", "value": true }
    },
    {
      "type": "select",
      "id": "theme",
      "label": "t:common.custom_color.theme.label",
      "options": [
        { "label": "t:common.custom_color.theme.options.light", "value": "light" },
        { "label": "t:common.custom_color.theme.options.dark", "value": "dark" }
      ],
      "default": "light",
      "visible_if": { "setting_id": "custom_color", "value": true }
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "label": "t:sections.testimonials.blocks.testimonial.label",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "t:sections.testimonials.blocks.testimonial.rating",
          "max": 5,
          "min": 1,
          "step": 1,
          "default": 4
        },
        {
          "type": "text",
          "id": "author",
          "label": "t:sections.testimonials.blocks.testimonial.author",
          "default": "t:sections.testimonials.blocks.testimonial.default.author"
        },
        { "type": "header", "content": "t:common.headers.content" },
        {
          "type": "select",
          "id": "content_type",
          "label": "t:sections.testimonials.blocks.testimonial.type.label",
          "options": [
            { "label": "t:sections.testimonials.blocks.testimonial.type.options.text", "value": "text" },
            { "label": "t:sections.testimonials.blocks.testimonial.type.options.image", "value": "image" }
          ],
          "default": "text"
        },
        {
          "type": "textarea",
          "id": "content",
          "label": "t:common.headers.content",
          "default": "t:sections.testimonials.blocks.testimonial.default.content",
          "visible_if": { "setting_id": "content_type", "value": "text" }
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:common.media.image",
          "visible_if": { "setting_id": "content_type", "value": "image" }
        },
        {
          "type": "textarea",
          "id": "image_alt",
          "label": "t:common.media.alt.label",
          "placeholder": "t:common.media.alt.placeholder",
          "visible_if": { "setting_id": "content_type", "value": "image" }
        }
      ]
    }
  ]
}
{% endschema %}
