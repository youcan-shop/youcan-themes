{{ 'section.header.css' | asset_url | stylesheet_tag }}

{% if section.settings.custom_color %}
  {% style %}
    #youcan-section--{{ section.id }}:has([ui-section="header"]) {
      --brand-lightness: {{ section.settings.color.lightness | divided_by: 100 }};
      --brand-chroma: {{ section.settings.color.chroma }};
      --brand-hue: {{ section.settings.color.oklch_hue }};
    }
  {% endstyle %}
{% endif %}

<div
  ui-section="header"
  {% if template.name == 'product' %}
    data-floating="true"
  {% endif %}
  {% if section.settings.custom_color %}
    data-custom-color
    data-theme="{{ section.settings.theme }}"
  {% endif %}
>
  {% unless template.name == 'product' %}
    <a class="logo" href="/">
      {% if section.settings.logo %}
        <img
          src="{{ section.settings.logo.src }}"
          alt="{{ section.settings.logo_alt | default: section.settings.heading | default: store.name }}"
          height="80"
          width="80"
          loading="eager"
        >
      {% else %}
        {% render 'misc.image-fallback' %}
      {% endif %}
    </a>
    <a class="heading" href="/">{{ section.settings.heading | default: store.name }}</a>
    {% if section.settings.description %}
      <p class="subheading">{{ section.settings.description }}</p>
    {% endif %}
    <div class="social-links">
      {% assign social_media = 'facebook,instagram,x_twitter,tiktok,whatsapp,messenger,snapchat,pinterest,youtube,linkedin,website' %}
      {% assign social_list = social_media | split: ',' %}

      {% for social_item in social_list %}
        {% assign href = settings[social_item] %}

        {% if href %}
          {% case social_item %}
            {% when 'facebook' %}
              <a ui-slot="button" data-mode="3d" data-size="md" data-as-icon aria-label="Facebook" href="{{ href }}" target="_blank">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24">
                  <path fill="currentColor" d="M9.101 23.691v-7.98H6.627v-3.667h2.474v-1.58c0-4.085 1.848-5.978 5.858-5.978c.401 0 .955.042 1.468.103a9 9 0 0 1 1.141.195v3.325a9 9 0 0 0-.653-.036a27 27 0 0 0-.733-.009c-.707 0-1.259.096-1.675.309a1.7 1.7 0 0 0-.679.622c-.258.42-.374.995-.374 1.752v1.297h3.919l-.386 2.103l-.287 1.564h-3.246v8.245C19.396 23.238 24 18.179 24 12.044c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.628 3.874 10.35 9.101 11.647"/>
                </svg>
              </a>
            {% when 'instagram' %}
              <a ui-slot="button" data-mode="3d" data-size="md" data-as-icon aria-label="Instagram" href="{{ href }}" target="_blank">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24">
                  <path fill="currentColor" d="M7.03.084c-1.277.06-2.149.264-2.91.563a5.9 5.9 0 0 0-2.124 1.388a5.9 5.9 0 0 0-1.38 2.127C.321 4.926.12 5.8.064 7.076s-.069 1.688-.063 4.947s.021 3.667.083 4.947c.061 1.277.264 2.149.563 2.911c.308.789.72 1.457 1.388 2.123a5.9 5.9 0 0 0 2.129 1.38c.763.295 1.636.496 2.913.552c1.278.056 1.689.069 4.947.063s3.668-.021 4.947-.082c1.28-.06 2.147-.265 2.91-.563a5.9 5.9 0 0 0 2.123-1.388a5.9 5.9 0 0 0 1.38-2.129c.295-.763.496-1.636.551-2.912c.056-1.28.07-1.69.063-4.948c-.006-3.258-.02-3.667-.081-4.947c-.06-1.28-.264-2.148-.564-2.911a5.9 5.9 0 0 0-1.387-2.123a5.9 5.9 0 0 0-2.128-1.38c-.764-.294-1.636-.496-2.914-.55C15.647.009 15.236-.006 11.977 0S8.31.021 7.03.084m.14 21.693c-1.17-.05-1.805-.245-2.228-.408a3.7 3.7 0 0 1-1.382-.895a3.7 3.7 0 0 1-.9-1.378c-.165-.423-.363-1.058-.417-2.228c-.06-1.264-.072-1.644-.08-4.848c-.006-3.204.006-3.583.061-4.848c.05-1.169.246-1.805.408-2.228c.216-.561.477-.96.895-1.382a3.7 3.7 0 0 1 1.379-.9c.423-.165 1.057-.361 2.227-.417c1.265-.06 1.644-.072 4.848-.08c3.203-.006 3.583.006 4.85.062c1.168.05 1.804.244 2.227.408c.56.216.96.475 1.382.895s.681.817.9 1.378c.165.422.362 1.056.417 2.227c.06 1.265.074 1.645.08 4.848c.005 3.203-.006 3.583-.061 4.848c-.051 1.17-.245 1.805-.408 2.23c-.216.56-.477.96-.896 1.38a3.7 3.7 0 0 1-1.378.9c-.422.165-1.058.362-2.226.418c-1.266.06-1.645.072-4.85.079s-3.582-.006-4.848-.06m9.783-16.192a1.44 1.44 0 1 0 1.437-1.442a1.44 1.44 0 0 0-1.437 1.442M5.839 12.012a6.161 6.161 0 1 0 12.323-.024a6.162 6.162 0 0 0-12.323.024M8 12.008A4 4 0 1 1 12.008 16A4 4 0 0 1 8 12.008"/>
                </svg>
              </a>
            {% when 'x_twitter' %}
              <a ui-slot="button" data-mode="3d" data-size="md" data-as-icon aria-label="X (Twitter)" href="{{ href }}" target="_blank">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24">
                  <path fill="currentColor" d="M14.234 10.162L22.977 0h-2.072l-7.591 8.824L7.251 0H.258l9.168 13.343L.258 24H2.33l8.016-9.318L16.749 24h6.993zm-2.837 3.299l-.929-1.329L3.076 1.56h3.182l5.965 8.532l.929 1.329l7.754 11.09h-3.182z"/>
                </svg>
              </a>
            {% when 'tiktok' %}
              <a ui-slot="button" data-mode="3d" data-size="md" data-as-icon aria-label="TikTok" href="{{ href }}" target="_blank">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24">
                  <path fill="currentColor" d="M16 1h-3.5v15.5c0 1.5-1.5 3-3 3s-3-.5-3-3c0-2 1.899-3.339 3.5-3V10c-6.12 0-7 5-7 6.5S3.977 23 9.5 23c4.522 0 6.5-3.5 6.5-6V8c1.146 1.018 2.922 1.357 5 1.5V6c-3.017 0-5-2.654-5-5"/>
                </svg>
              </a>
            {% when 'whatsapp' %}
              <a ui-slot="button" data-mode="3d" data-size="md" data-as-icon aria-label="WhatsApp" href="{{ href }}" target="_blank">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24">
                  <path fill="currentColor" fill-rule="evenodd" d="M1 12C1 5.925 5.925 1 12 1s11 4.925 11 11s-4.925 11-11 11c-1.936 0-3.757-.5-5.338-1.38L1.4 22.6l.98-5.262A10.95 10.95 0 0 1 1 12m6.147-5.353c.654-.655 1.527-.713 1.998-.69c.435.02.776.272.984.564l.952 1.334a1.5 1.5 0 0 1-.16 1.932l-.674.673c.223.544.67 1.42 1.272 2.021s1.477 1.05 2.02 1.273l.675-.674a1.5 1.5 0 0 1 1.931-.16l1.335.951c.291.209.544.55.564.984c.022.471-.036 1.344-.69 1.999c-1.067 1.066-2.741 1.077-4.264.659c-1.55-.426-3.13-1.34-4.197-2.406c-1.065-1.066-1.98-2.646-2.406-4.197c-.418-1.523-.407-3.197.66-4.263" clip-rule="evenodd"/>
                </svg>
              </a>
            {% when 'messenger' %}
              <a ui-slot="button" data-mode="3d" data-size="md" data-as-icon aria-label="Messenger" href="{{ href }}" target="_blank">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24">
                  <path fill="currentColor" fill-rule="evenodd" d="M1.25 11.267C1.25 5.574 6.086 1 12 1s10.75 4.574 10.75 10.267S17.914 21.535 12 21.535a11.2 11.2 0 0 1-2.91-.381l-2.06 1.548c-.974.732-2.363.036-2.363-1.18v-2.747c-2.099-1.87-3.417-4.54-3.417-7.508m5.5 2.858l2.828-1.414a1 1 0 0 1 .853-.02l3.25 1.445a1 1 0 0 0 1.27-.41l2.626-4.501a.25.25 0 0 0-.328-.35l-2.827 1.414a1 1 0 0 1-.853.02l-3.25-1.445a1 1 0 0 0-1.27.41l-2.626 4.501a.25.25 0 0 0 .328.35Z" clip-rule="evenodd"/>
                </svg>
              </a>
            {% when 'snapchat' %}
              <a ui-slot="button" data-mode="3d" data-size="md" data-as-icon aria-label="Snapchat" href="{{ href }}" target="_blank">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24">
                  <path fill="currentColor" d="M7.926 2.432C9.298 1.266 10.93 1 12 1s2.702.266 4.074 1.432c1.284 1.091 2.269 2.91 2.409 5.836l.296-.118a2.297 2.297 0 0 1 1.953 4.148l-2.032.931c.267.405.698.923 1.243 1.468c.75.75 1.66 1.494 2.522 1.985c.302.173.566.453.674.795a1 1 0 0 1-.328 1.103c-.547.45-1.383.812-2.357.9c-.08.387-.262.699-.546.928c-.366.295-.83.393-1.235.432c-.305.03-.637.03-.93.029h-.269c-.385.005-.633.03-.78.092c-.2.084-.445.236-.761.445l-.19.127c-.26.173-.552.369-.862.554c-.78.465-1.748.913-2.881.913s-2.101-.448-2.881-.913c-.31-.185-.602-.38-.862-.554l-.19-.127c-.316-.21-.56-.36-.76-.445c-.148-.062-.396-.087-.781-.091l-.269-.001c-.293 0-.625 0-.93-.029c-.405-.039-.869-.137-1.235-.432a1.56 1.56 0 0 1-.546-.928c-.974-.088-1.81-.45-2.357-.9a1 1 0 0 1-.328-1.103c.108-.342.372-.622.674-.795c.862-.491 1.772-1.235 2.522-1.985c.545-.545.976-1.063 1.243-1.468l-2.032-.93A2.297 2.297 0 0 1 5.221 8.15l.296.117c.14-2.925 1.125-4.745 2.41-5.836Z"/>
                </svg>
              </a>
            {% when 'pinterest' %}
              <a ui-slot="button" data-mode="3d" data-size="md" data-as-icon aria-label="Pinterest" href="{{ href }}" target="_blank">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24">
                  <path fill="currentColor" d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162c-.105-.949-.199-2.403.041-3.439c.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911c1.024 0 1.518.769 1.518 1.688c0 1.029-.653 2.567-.992 3.992c-.285 1.193.6 2.165 1.775 2.165c2.128 0 3.768-2.245 3.768-5.487c0-2.861-2.063-4.869-5.008-4.869c-3.41 0-5.409 2.562-5.409 5.199c0 1.033.394 2.143.889 2.741c.099.12.112.225.085.345c-.09.375-.293 1.199-.334 1.363c-.053.225-.172.271-.401.165c-1.495-.69-2.433-2.878-2.433-4.646c0-3.776 2.748-7.252 7.92-7.252c4.158 0 7.392 2.967 7.392 6.923c0 4.135-2.607 7.462-6.233 7.462c-1.214 0-2.354-.629-2.758-1.379l-.749 2.848c-.269 1.045-1.004 2.352-1.498 3.146c1.123.345 2.306.535 3.55.535c6.607 0 11.985-5.365 11.985-11.987C23.97 5.39 18.592.026 11.985.026z"/>>
                </svg>
              </a>
            {% when 'youtube' %}
              <a ui-slot="button" data-mode="3d" data-size="md" data-as-icon aria-label="YouTube" href="{{ href }}" target="_blank">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24">
                  <path fill="currentColor" fill-rule="evenodd" d="M1.172 7.693A56 56 0 0 0 1 12c0 1.632.08 3.167.182 4.44c.146 1.817 1.531 3.206 3.318 3.33c1.794.125 4.305.23 7.5.23s5.706-.105 7.5-.23c1.787-.124 3.172-1.513 3.318-3.33c.102-1.273.182-2.808.182-4.44c0-1.576-.074-3.06-.172-4.307a3.73 3.73 0 0 0-3.46-3.46C17.59 4.107 15.164 4 12 4s-5.591.107-7.368.233a3.73 3.73 0 0 0-3.46 3.46M15.5 12L10 9v6z" clip-rule="evenodd"/>
                </svg>
              </a>
            {% when 'linkedin' %}
              <a ui-slot="button" data-mode="3d" data-size="md" data-as-icon aria-label="LinkedIn" href="{{ href }}" target="_blank">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24">
                  <path fill="currentColor" fill-rule="evenodd" d="M3.5 6a2.5 2.5 0 1 0 0-5a2.5 2.5 0 0 0 0 5M6 23V8H1v15zM8 8h4.5v1.946C13.216 9.005 14.746 8 17.5 8c4.33 0 5.5 4.32 5.5 7v8h-5v-8c0-1-.5-3-2.5-3c-1.42 0-2.42 1.008-3 1.951V23H8z" clip-rule="evenodd"/>
                </svg>
              </a>
            {% when 'website' %}
              <a ui-slot="button" data-mode="3d" data-size="md" data-as-icon aria-label="Website" href="{{ href }}" target="_blank">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                >
                  <path d="M1.33789 9.89164C1.24347 10.3759 1.19626 10.6181 1.34722 10.8016C1.49818 10.9852 1.76037 10.9852 2.28475 10.9852H5.99473C6.4489 10.9852 6.67599 10.9852 6.82072 10.8508C6.96545 10.7164 6.98312 10.4831 7.01844 10.0166C7.17915 7.89382 7.5946 5.96801 8.20067 4.44646C8.58093 3.4918 9.08165 2.54041 9.82321 1.81486C10.14 1.50495 10.2983 1.34999 10.2621 1.28307C10.2258 1.21614 10.0244 1.2613 9.62167 1.35162C5.43808 2.28982 2.16472 5.65075 1.33789 9.89164Z" fill="currentColor"></path>
                  <path d="M2.28479 13.015C1.76039 13.015 1.4982 13.015 1.34724 13.1986C1.19628 13.3821 1.2435 13.6243 1.33793 14.1086C2.1648 18.3494 5.43809 21.7102 9.62158 22.6484C10.0242 22.7387 10.2256 22.7838 10.2618 22.7169C10.2981 22.65 10.1398 22.4951 9.82312 22.1853C9.0816 21.4597 8.58091 20.5084 8.20067 19.5538C7.5946 18.0322 7.17915 16.1064 7.01844 13.9837C6.98312 13.5171 6.96545 13.2838 6.82072 13.1494C6.67599 13.015 6.4489 13.015 5.99473 13.015H2.28479Z" fill="currentColor"></path>
                  <path d="M14.171 22.1865C13.8543 22.4961 13.6959 22.651 13.7322 22.7179C13.7684 22.7848 13.9697 22.7398 14.3723 22.6498C18.5587 21.7135 21.8348 18.3514 22.6621 14.1086C22.7565 13.6243 22.8037 13.3821 22.6528 13.1986C22.5018 13.015 22.2396 13.015 21.7152 13.015H18.0007C17.5465 13.015 17.3194 13.015 17.1747 13.1494C17.0299 13.2838 17.0123 13.5171 16.9769 13.9837C16.8162 16.1064 16.4008 18.0322 15.7947 19.5538C15.4143 20.5089 14.9132 21.4608 14.171 22.1865Z" fill="currentColor"></path>
                  <path d="M21.7152 10.9852C22.2396 10.9852 22.5018 10.9852 22.6528 10.8016C22.8037 10.6181 22.7565 10.3759 22.6621 9.89164C21.8349 5.6487 18.5587 2.28656 14.3722 1.35026C13.9695 1.26019 13.7681 1.21516 13.7319 1.28209C13.6957 1.34903 13.8541 1.5039 14.1709 1.81363C14.9132 2.5393 15.4143 3.49129 15.7947 4.44646C16.4008 5.96801 16.8162 7.89382 16.9769 10.0166C17.0123 10.4831 17.0299 10.7164 17.1747 10.8508C17.3194 10.9852 17.5465 10.9852 18.0007 10.9852H21.7152Z" fill="currentColor"></path>
                  <path d="M13.9365 5.30032C14.4362 6.52593 14.8079 8.13294 14.9692 9.95969C15.0113 10.437 15.0324 10.6757 14.8819 10.8378C14.7315 11 14.4815 11 13.9815 11H10.0185C9.51853 11 9.26852 11 9.11807 10.8378C8.96763 10.6757 8.9887 10.437 9.03085 9.95969C9.19214 8.13294 9.56382 6.52593 10.0635 5.30032C10.404 4.46523 10.7839 3.85653 11.1536 3.47296C11.5213 3.0915 11.8077 3 12 3C12.1923 3 12.4787 3.0915 12.8464 3.47296C13.2161 3.85653 13.596 4.46523 13.9365 5.30032Z" fill="currentColor"></path>
                  <path d="M10.0635 18.6997C9.56382 17.4741 9.19214 15.8671 9.03085 14.0403C8.9887 13.563 8.96763 13.3243 9.11807 13.1622C9.26852 13 9.51853 13 10.0185 13H13.9815C14.4815 13 14.7315 13 14.8819 13.1622C15.0324 13.3243 15.0113 13.563 14.9692 14.0403C14.8079 15.8671 14.4362 17.4741 13.9365 18.6997C13.596 19.5348 13.2161 20.1435 12.8464 20.527C12.4787 20.9085 12.1923 21 12 21C11.8077 21 11.5213 20.9085 11.1536 20.527C10.7839 20.1435 10.404 19.5348 10.0635 18.6997Z" fill="currentColor"></path>
                </svg>
              </a>
          {% endcase %}
        {% endif %}
      {% endfor %}
    </div>

    {% render 'misc.menu-drawer' %}
  {% endunless %}

  {% if template.name == 'product' %}
    <a
      class="back-trigger"
      ui-slot="button"
      data-mode="3d"
      data-size="md"
      data-as-icon
      data-flip-icon-in-rtl
      aria-label="Back to home"
      href="/"
    >
      {% render 'misc.icon', name: 'hgi-arrow-left-01' %}
    </a>
  {% endif %}
  {% render 'misc.cart-drawer' %}
</div>

{% schema %}
{
  "label": "t:sections.header.label",
  "tag": "header",
  "settings": [
    { "type": "header", "content": "t:common.headers.header" },
    {
      "type": "text",
      "id": "heading",
      "label": "t:common.header.heading",
      "default": "t:sections.header.default.heading"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:common.header.description",
      "default": "t:sections.header.default.description"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "t:common.header.logo"
    },
    {
      "type": "textarea",
      "id": "logo_alt",
      "label": "t:common.media.alt.label",
      "placeholder": "t:common.media.alt.placeholder"
    },
    { "type": "header", "content": "t:common.headers.appearance" },
    { "type": "checkbox", "id": "custom_color", "label": "t:common.custom_color.label", "default": false },
    {
      "type": "color",
      "id": "color",
      "label": "t:common.custom_color.color",
      "default": "#121212",
      "visible_if": { "setting_id": "custom_color", "value": true }
    },
    {
      "type": "select",
      "id": "theme",
      "label": "t:common.custom_color.theme.label",
      "options": [
        { "label": "t:common.custom_color.theme.options.light", "value": "light" },
        { "label": "t:common.custom_color.theme.options.dark", "value": "dark" }
      ],
      "default": "light",
      "visible_if": { "setting_id": "custom_color", "value": true }
    },
    { "type": "header", "content": "t:sections.header.blocks.cart_drawer" },
    { "type": "header", "content": "t:sections.header.blocks.note_1" },
    {
      "type": "text",
      "id": "note_title_1",
      "label": "t:sections.header.blocks.note.title.label",
      "placeholder": "t:sections.header.blocks.note.title.default"
    },
    {
      "type": "textarea",
      "id": "note_description_1",
      "label": "t:common.header.description",
      "placeholder": "t:sections.header.blocks.note.description.default"
    },
    { "type": "header", "content": "t:sections.header.blocks.note_2" },
    {
      "type": "text",
      "id": "note_title_2",
      "label": "t:sections.header.blocks.note.title.label",
      "placeholder": "t:sections.header.blocks.note.title.default"
    },
    {
      "type": "textarea",
      "id": "note_description_2",
      "label": "t:common.header.description",
      "placeholder": "t:sections.header.blocks.note.description.default"
    },
    { "type": "header", "content": "t:sections.header.blocks.note_3" },
    {
      "type": "text",
      "id": "note_title_3",
      "label": "t:sections.header.blocks.note.title.label",
      "placeholder": "t:sections.header.blocks.note.title.default"
    },
    {
      "type": "textarea",
      "id": "note_description_3",
      "label": "t:common.header.description",
      "placeholder": "t:sections.header.blocks.note.description.default"
    },
    { "type": "header", "content": "t:sections.header.blocks.recommendations.label" },
    {
      "type": "text",
      "id": "recommendations_header",
      "label": "t:common.headers.header",
      "default": "t:sections.header.blocks.recommendations.default.header",
      "visible_if": { "setting_id": "show_recommendations", "value": true }
    },
    {
      "type": "category",
      "id": "recommended_collection",
      "label": "t:common.headers.collection",
      "visible_if": { "setting_id": "show_recommendations", "value": true }
    },
    {
