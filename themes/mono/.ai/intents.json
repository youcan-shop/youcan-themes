{
  "_readme": "Maps seller intent keywords to section types. Use this before selecting sections, match the seller's request against these patterns first.",
  "hero": {
    "keywords": [
      "hero",
      "banner image",
      "top image",
      "header image",
      "first section",
      "above the fold",
      "main visual",
      "cover"
    ],
    "sections": [
      "slideshow"
    ],
    "notes": "Always the first section in order on homepage"
  },
  "announcement": {
    "keywords": [
      "announcement",
      "marquee",
      "ticker",
      "scrolling text",
      "notice",
      "promo bar",
      "top bar"
    ],
    "sections": [
      "banner"
    ],
    "notes": "Pairs well with any section. Often placed right after slideshow or at the very top"
  },
  "flash_sale": {
    "keywords": [
      "flash sale",
      "limited offer",
      "deal",
      "sale ends",
      "hurry",
      "time limited",
      "expires",
      "offer ends",
      "urgency"
    ],
    "sections": [
      "countdown",
      "banner"
    ],
    "notes": "countdown for the timer block, banner for the announcement strip. Use both together for maximum urgency"
  },
