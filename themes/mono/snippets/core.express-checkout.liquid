{{ 'core.express-checkout.css' | asset_url | stylesheet_tag }}

{% comment %}
  Renders a form

  Accepts:
  - fields: {Array} Checkout fields
  - style: {String} Checkout style (default | open-drawer)

  Usage:
  {% render 'core.express-checkout', fields: [...] %}
{% endcomment %}

{% assign linked_fields = 'country,region,city' %}
{% assign has_linked_fields = checkout.linked_fields %}
{% assign has_phone_validation = checkout.phone_validation %}

{% if style == 'open-drawer' %}
  <form
    class="express-checkout-drawer"
    ui-slot="drawer-content"
    id="express-checkout-{{ product.id }}"
    popover
    ui-order-form
  >
    <div ui-slot="drawer-header">
      <h2 ui-slot="drawer-title">{{ 'express_checkout.title' | t }}</h2>
      <button
        type="button"
        ui-slot="button"
        data-variant="primary"
        data-mode="ghost"
        data-size="md"
        aria-label="Close"
        popovertarget="express-checkout-{{ product.id }}"
      >
        {% render 'misc.icon', name: 'hgi-cancel-01' %}
      </button>
    </div>
    <div ui-slot="drawer-body">
      <ui-express-checkout>
        {% for field in checkout.fields %}
          {% assign field_name = field.name %}

          {% if field.custom %}
            {% assign field_name = 'extra_fields[' | append: field.name | append: ']' %}
          {% endif %}

          {% unless has_linked_fields and linked_fields contains field.name %}
            {% if field.name == 'phone' and has_phone_validation %}
              {% render 'core.phone-validation', field: field %}
            {% else %}
              <label ui-express-checkout="field">
                <span ui-slot="label">{{ field.display_name }}</span>
                {% case field.type %}
                  {% when 'text', 'number', 'hidden' %}
                    <input
                      ui-slot="input"
                      type="{{ field.type }}"
                      name="{{ field_name }}"
                      value="{{ field.default_value }}"
                      placeholder="{{ field.placeholder }}"
                      {% if field.required %}
                        required
                      {% endif %}
                    >
                  {% when 'textarea' %}
                    <textarea
                      ui-slot="textarea"
                      name="{{ field_name }}"
                      placeholder="{{ field.placeholder }}"
                      {% if field.required %}
                        required
                      {% endif %}
                    ></textarea>
                  {% when 'select' %}
                    <select
                      ui-slot="input"
                      name="{{ field_name }}"
                      {% if field.required %}
                        required
                      {% endif %}
                    >
                      {% for opt in field.options %}
                        <option
                          value="{{ opt }}"
                          {% if option == field.default_value %}
                            selected
                          {% endif %}
                        >
                          {{ opt }}
                        </option>
                      {% endfor %}
                    </select>
                {% endcase %}
              </label>
            {% endif %}
          {% endunless %}
        {% endfor %}

        {% if has_linked_fields %}
          {% render 'core.linked-fields', fields: checkout.fields %}
        {% endif %}
      </ui-express-checkout>
      <div class="bio">
        <a class="media" href="{{ product.url }}">
          {% if product.preview_image %}
            <img
              src="{{ product.preview_image.original }}"
              alt="{{ product.name }}"
              height="150"
              width="150"
              loading="lazy"
            >
          {% else %}
            {% render 'misc.image-fallback', type: 'product' %}
          {% endif %}
        </a>
        <div class="info">
          <a class="title" href="{{ product.url }}">{{ product.name }}</a>
          <div class="rating">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
            >
              <path d="M11.9961 1.25C13.0454 1.25 13.8719 2.04253 14.3995 3.11191L16.1616 6.66516C16.215 6.77513 16.3417 6.92998 16.5321 7.07164C16.7223 7.21315 16.9086 7.29121 17.0311 7.3118L20.2207 7.84613C21.3729 8.03973 22.3386 8.60449 22.6521 9.5879C22.9653 10.5705 22.5064 11.5916 21.6778 12.4216L21.677 12.4225L19.1991 14.9209C19.1009 15.0199 18.9909 15.2064 18.9219 15.4494C18.8534 15.6908 18.8473 15.9107 18.8784 16.0527L18.8788 16.0547L19.5877 19.1454C19.8818 20.4317 19.7843 21.7073 18.8771 22.3742C17.9667 23.0433 16.7227 22.7467 15.5925 22.0736L12.6026 20.289C12.477 20.214 12.2614 20.1532 12.0011 20.1532C11.7427 20.1532 11.5226 20.2132 11.3888 20.291L11.3869 20.2921L8.40288 22.0732C7.27405 22.7487 6.03154 23.04 5.12111 22.3702C4.21449 21.7032 4.11214 20.43 4.40711 19.1447L5.1159 16.0547L5.11633 16.0527C5.14741 15.9107 5.14133 15.6908 5.0728 15.4494C5.0038 15.2064 4.89379 15.0199 4.79558 14.9209L2.31585 12.4206C1.49265 11.5906 1.03521 10.5704 1.34595 9.58925C1.65759 8.60525 2.62143 8.0398 3.77433 7.84606L6.96132 7.31219L6.96233 7.31202C7.07917 7.29175 7.2627 7.21456 7.45248 7.07268C7.64261 6.93054 7.76959 6.77535 7.82312 6.66516L7.82582 6.65967L9.58562 3.11097L9.58632 3.10957C10.119 2.04108 10.948 1.25 11.9961 1.25Z" fill="currentColor"></path>
            </svg>
            ({{ product.averageRating }})
          </div>
        </div>
      </div>
      <div class="core">
        <div class="qty">
          <span class="label">{{ 'general.quantity' | t }}</span>
          {% render 'core.quantity' %}
        </div>
        <span class="price">{{ price | default: 0 | money }}</span>
      </div>
    </div>
    <div ui-slot="drawer-footer">
      <button
        type="button"
        ui-slot="button"
        data-variant="primary"
        data-mode="ghost"
        data-size="lg"
        popovertarget="express-checkout-{{ product.id }}"
      >
        {{ 'general.discard' | t }}
      </button>
      {% render 'core.shop-button', is_express_checkout: true, size: 'lg' %}
    </div>
  </form>
{% else %}
  <form id="express-checkout" class="express-checkout-default" ui-order-form>
    {% if settings.form_heading or settings.form_description %}
      <div class="head">
        {% if settings.form_heading %}
          <h2 class="title">{{ settings.form_heading }}</h2>
        {% endif %}
        {% if settings.form_description %}
          <p class="description">{{ settings.form_description }}</p>
        {% endif %}
      </div>
    {% endif %}
    <ui-express-checkout>
      {% for field in checkout.fields %}
        {% assign field_name = field.name %}

        {% if field.custom %}
          {% assign field_name = 'extra_fields[' | append: field.name | append: ']' %}
        {% endif %}

        {% unless has_linked_fields and linked_fields contains field.name %}
          {% if field.name == 'phone' and has_phone_validation %}
            {% render 'core.phone-validation', field: field %}
          {% else %}
            <label ui-express-checkout="field">
              <span ui-slot="label">{{ field.display_name }}</span>
              {% case field.type %}
                {% when 'text', 'number', 'hidden' %}
                  <input
                    ui-slot="input"
                    type="{{ field.type }}"
                    name="{{ field_name }}"
                    value="{{ field.default_value }}"
                    placeholder="{{ field.placeholder }}"
                    {% if field.required %}
                      required
                    {% endif %}
                  >
                {% when 'textarea' %}
                  <textarea
                    ui-slot="textarea"
                    name="{{ field_name }}"
                    placeholder="{{ field.placeholder }}"
                    {% if field.required %}
                      required
                    {% endif %}
                  ></textarea>
                {% when 'select' %}
                  <select
                    ui-slot="input"
                    name="{{ field_name }}"
                    {% if field.required %}
                      required
                    {% endif %}
                  >
                    {% for opt in field.options %}
                      <option
                        value="{{ opt }}"
                        {% if option == field.default_value %}
                          selected
                        {% endif %}
                      >
                        {{ opt }}
                      </option>
                    {% endfor %}
                  </select>
              {% endcase %}
            </label>
          {% endif %}
        {% endunless %}
      {% endfor %}

      {% if has_linked_fields %}
        {% render 'core.linked-fields', fields: checkout.fields %}
      {% endif %}
    </ui-express-checkout>

    <div class="actions">
      {% render 'core.quantity', size: 'md', variant: '3d' %}
      {% render 'core.shop-button', is_express_checkout: true, size: 'lg' %}
    </div>
  </form>
{% endif %}

{% if has_linked_fields or has_phone_validation %}
  {% javascript %}
    if (!window.storeMarketCountries) {
      window.storeMarketCountries = new Promise((resolve) => {
        document.addEventListener('DOMContentLoaded', async () => {
          const data = await youcanjs.misc.getStoreMarketCountries();
          resolve(data);
        });
      });
      window.storeRegions = {};
      window.storeCities = {};
    }
  {% endjavascript %}
{% endif %}
