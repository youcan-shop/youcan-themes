{% comment %}
  Renders all necessary assets (components, icons, fonts, YouCan JS, cart, variants, error messages..)

  Usage:
  {% render '_config' %}
{% endcomment %}

{% comment %} Favicon {% endcomment %}
{% assign words = store.name | split: '' %}
{% assign first = words[0] | upcase | slice: 0 %}
{% assign second = words[1] | upcase | slice: 0 %}
{% assign slug_initial = first | append: second %}
{% if slug_initial == blank %}{% assign slug_initial = store.name | upcase | slice: 0, 2 %}{% endif %}
{% if slug_initial == blank %}{% assign slug_initial = 'ST' %}{% endif %}

{% assign color = '%23' | append: settings.brand_color.hex | remove: '#' %}
{% if color == blank %}{% assign color = '121212' %}{% endif %}
{% assign favicon = "data:image/svg+xml, <svg xmlns='http://www.w3.org/2000/svg' width='48' height='48' viewBox='0 0 48 48'><rect width='100%' height='100%' fill='[COLOR]'/><text x='50%' y='50%' font-size='32' fill='white' text-anchor='middle' dy='10'>[SLUG]</text></svg>" %}
{% assign favicon = favicon | replace: '[SLUG]', slug_initial %}
{% assign favicon = favicon | replace: '[COLOR]', color %}

{% if settings.favicon.src %}
  {% assign favicon = settings.favicon.src %}
{% endif %}

<link
  {% unless settings.favicon.src != null %}
    type="image/svg+xml"
  {% endunless %}
  rel="shortcut icon"
  href="{{ favicon }}"
>

{% comment %}
  Global Styles (layout + components)
{% endcomment %}
{{ 'main.css' | asset_url | stylesheet_tag }}

{% comment %}
  Icons
{% endcomment %}
<link rel="stylesheet" href="https://cdn.hugeicons.com/font/hgi-stroke-rounded.css">

{% comment %}
  Font (default: DM Sans | Almarai)
{% endcomment %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css?family={{ settings.body_font }}|{{ settings.heading_font }}"
>

{% style %}
  :root {
    /* Base */
    --font-family: '{{ settings.body_font | replace: '+', ' ' }}';
    --font-heading-family: '{{ settings.heading_font | replace: '+', ' ' }}';

    /* Spacing */
    --section-spacing: {{ settings.section_spacing }}px;

    /* Radius */
    {% case settings.border_radius %}
      {% when 'soft' %}
        --radius-button: var(--radius-8);
        --radius-section: var(--radius-8);
      {% when 'softer' %}
        --radius-button: var(--radius-rounded);
        --radius-section: var(--radius-20);
    {% endcase %}

    /* Colors */
    --brand-lightness: {{ settings.brand_color.lightness | divided_by: 100 }};
    --brand-chroma: {{ settings.brand_color.chroma }};
    --brand-hue: {{ settings.brand_color.oklch_hue }};
  }

  {% if settings.background_image %}
    body main {
      background-image: url("{{ settings.background_image.src }}");

      .youcan-section {
        background-color: transparent;
        border-color: transparent;

        [ui-section] {
          background-color: var(--color-on-primary);

          &[ui-section="header"],
          &[ui-section="slideshow"],
          &[ui-section="collections"],
          &[ui-section="faqs"],
          &[ui-section="testimonials"],
          &[ui-section="blogs"],
          &[ui-section="multicolumn"],
          &[ui-section="search"],
          &[ui-section="product-information"],
          &[ui-section="reviews"],
          &[ui-section="all-collections"],
          &[ui-section="single-collection"],
          &[ui-section="page"],
          &[ui-section="cart"],
          &[ui-section="order-summary"],
          &[ui-section="video-reviews"],
          &[ui-section="footer"] {
            background-color: transparent;
          }

          &[ui-section="collections"] {
            .list .collection-item {
              background-color: var(--color-on-primary);
            }
          }

          &[ui-section="testimonials"] {
            .list .testimonial-item {
              background-color: var(--color-on-primary);
            }
          }

          &[ui-section="reviews"] {
            .list .review-item {
              background-color: var(--color-on-primary);
            }
          }

          &[ui-section="blogs"] {
            .list .blog-item {
              background-color: var(--color-on-primary);
            }
          }

          &[ui-section="multicolumn"] {
            .list .column-item {
              background-color: var(--color-on-primary);
            }
          }

          &[ui-section="all-collections"] {
            .list .collection-item {
              background-color: var(--color-on-primary);
            }
          }

          &[ui-section="single-collection"] {
            .head form [ui-slot="input"] {
              background-color: var(--color-primary-container);
            }

            .collections-list .product-item {
              background-color: var(--color-on-primary);
            }
          }

          &[ui-section="cart"] {
            .list .product-item, ui-summary-box .coupon, ui-summary-box .summary {
              background-color: var(--color-on-primary);
            }
          }

          &[ui-section="search"] {
            .list .product-item {
              background-color: var(--color-on-primary);
            }
          }

          &[ui-section=order-summary] {
            .summary {
              background-color: var(--color-on-primary);
            }
          }

          [ui-slot="accordion-item"] {
            background-color: var(--color-on-primary);
          }

          [ui-slot="button"][data-mode="stroke"] {
            background-color: var(--color-on-primary);

            &:hover:not(:disabled, [aria-disabled="true"]) {
              background-color: var(--color-on-primary);
            }
          }

          .add-ons .list .product-item {
            background-color: var(--color-on-primary);
          }

          .express-checkout-default {
            background-color: var(--color-on-primary);
          }
        }
      }
    }
  {% else %}
  {% endif %}
{% endstyle %}

{{ content_for_header }}

