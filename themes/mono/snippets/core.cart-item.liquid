{% comment %}
  Renders cart item template (cart page)

  Accepts:
  - product: {Object} cart item info

  Usage:
  {% render 'core.cart-item', product: {...} %}
{% endcomment %}

<div class="product-item">
  <div class="media" ui-cart-item="image">
    <img
      src="{{ product.image }}"
      alt="{{ product.name }}"
      height="100%"
      width="100%"
      loading="lazy"
      {% if product.image contains '/store-front/images/product-default' %}
        hidden
      {% endif %}
    >
    {% if product.image contains '/store-front/images/product-default' %}
      {% render 'misc.image-fallback', type: 'product', icon_size: 40 %}
    {% else %}
      {% render 'misc.image-fallback', type: 'product', icon_size: 40, hidden: true %}
    {% endif %}
  </div>
  <div class="content">
    <div class="info">
      <a class="name" ui-cart-item="title" href="{{ product.url }}">{{ product.name }}</a>
      <span class="price" ui-cart-item="price" hidden>{{ product.price | default: 0 | money }}</span>
      {% assign subtotal = product.quantity | times: product.price %}
      <span class="price" ui-cart-item="subtotal">{{ subtotal | money }}</span>
      <div
        class="variants"
        ui-cart-item="variant"
        {% if product.variations == null or product.variations.default %}
          hidden
        {% endif %}
      >
        {% for variant in product.variations %}
          <span>{{ variant[1] }}</span>
        {% endfor %}
      </div>
    </div>
    <div class="actions">
      {% render 'core.quantity' %}
      <ui-cart-remove item="{{ product.id }}" product-variant="{{ product.product_variant_id }}">
        <button
          ui-slot="button"
          data-mode="lighter"
          data-size="xs"
          data-as-icon
          aria-label="Remove"
          ui-cart-item="delete-button"
        >
          {% render 'misc.icon', name: 'hgi-delete-02' %}
        </button>
      </ui-cart-remove>
    </div>
  </div>
</div>
