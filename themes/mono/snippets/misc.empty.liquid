{% comment %}
  Renders an empty message state

  Accepts:
  - type: {String} "product" | "collection (s)" | "cart" | "block"
  - hidden: {Boolean} (optional) Hide element

  Usage:
  {% render 'misc-empty' %}
{% endcomment %}

{% case type %}
  {% when 'product' %}
    {% assign heading = 'empty.search.heading' | t %}
    {% assign description = 'empty.search.description' | t %}
    {% assign action_label = 'empty.search.button' | t %}
    {% assign action_url = '/search' %}
  {% when 'collection' %}
    {% assign heading = 'empty.collection.heading' | t %}
    {% assign description = 'empty.collection.description' | t %}
    {% assign action_label = 'empty.collection.button' | t %}
    {% assign action_url = '/collections' %}
  {% when 'collections' %}
    {% assign heading = 'empty.collections.heading' | t %}
    {% assign description = 'empty.collections.description' | t %}
    {% assign action_label = 'empty.collections.button' | t %}
    {% assign action_url = '/search' %}
  {% when 'cart' %}
    {% assign heading = 'empty.cart.heading' | t %}
    {% assign description = 'empty.cart.description' | t %}
    {% assign action_label = 'empty.cart.button' | t %}
    {% assign action_url = '/search' %}
  {% when 'block' %}
    {% assign heading = 'empty.block.heading' | t %}
  {% when 'review' %}
    {% assign heading = 'empty.review.heading' | t %}
{% endcase %}

<ui-empty
  {% if hidden %}
    hidden
  {% endif %}
>
