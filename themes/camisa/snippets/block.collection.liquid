{% comment %}
  Renders a collection item (Block)

  Accepts:
  - variant: {String} "stroke" | "underline"
  - collection: {Object} Item info

  Usage:
  {% render 'block.collection', collection: {...} %}
{% endcomment %}

{% assign collection = collection.settings.collection | default: collection %}

<li ui-block="collection" {{ collection.youcan_attributes }}>
  <a href="/collections/{{ collection.slug }}">
    <div class="media" data-image-ratio="{{ settings.collection_image_ratio }}">
      {% if collection.preview_image %}
        <img
          srcset="
            {{ collection.preview_image.medium }} 480w,
            {{ collection.preview_image.large }} 800w,
            {{ collection.preview_image.original }} 1200w
          "
          sizes="
            (max-width: 640px) 50vw,
            (max-width: 768px) 33vw,
            (max-width: 1024px) 25vw,
            33vw
          "
          src="{{ collection.preview_image.original }}"
          alt="{{ collection.name }}"
          height="100%"
          width="100%"
          {% if template.name == 'list-collections' and forloop.index < 5 %}
            loading="eager"
          {% else %}
            loading="lazy"
          {% endif %}
        >
      {% else %}
        {% render 'misc.image-fallback', icon_size: 40 %}
      {% endif %}
    </div>

    <span class="name">
      {{ collection.name | default: 'collection.title' | t }}
    </span>
  </a>
</li>
