{{ 'misc.add-review.js' | asset_url | script_tag_deferred }}

{% comment %}
  Renders form modal where users can add a review

  Usage:
  {% render 'misc.add-review' %}
{% endcomment %}

<button
  ui-slot="link-button"
  data-variant="gray"
  data-size="md"
  data-underline="true"
  popovertarget="add-review"
>
  {{ 'reviews.add_review.action' | t }}
</button>

<ui-add-review
  class="add-review-modal"
  ui-slot="modal-content"
  popover
  id="add-review"
  product-id="{{ product.id }}"
>
  <div ui-slot="modal-header">
    <h3 ui-slot="modal-title">{{ 'reviews.add_review.title' | t }}</h3>
    <button
      ui-slot="button"
      data-variant="primary"
      data-mode="ghost"
      data-size="md"
      aria-label="Close"
      popovertarget="add-review"
      type="button"
    >
      {% render 'misc.icon', name: 'hgi-cancel-01' %}
    </button>
  </div>
  <form>
    <div ui-slot="modal-body">
      <div class="field">
        <label ui-slot="label" for="rating">
          {{ 'reviews.add_review.fields.rating' | t }}
        </label>
        <div class="rating-bar">
          <div ui-slot="rating-bar" data-variant="group" data-style="star" role="group">
            {% for star in (1..5) %}
              <label ui-slot="rating-item">
                <span ui-slot="sr">{{ star }}</span>
                <input
                  type="radio"
                  name="rating"
                  value="{{ star }}"
                  {% if star == 4 %}
                    checked
                  {% endif %}
                  ui-add-review="star"
                >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="32"
                  height="32"
                  viewBox="0 0 24 24"
                  fill="none"
                >
                  <path
                    d="M11.9961 1.25C13.0454 1.25 13.8719 2.04253 14.3995 3.11191L16.1616 6.66516C16.215 6.77513 16.3417 6.92998 16.5321 7.07164C16.7223 7.21315 16.9086 7.29121 17.0311 7.3118L20.2207 7.84613C21.3729 8.03973 22.3386 8.60449 22.6521 9.5879C22.9653 10.5705 22.5064 11.5916 21.6778 12.4216L21.677 12.4225L19.1991 14.9209C19.1009 15.0199 18.9909 15.2064 18.9219 15.4494C18.8534 15.6908 18.8473 15.9107 18.8784 16.0527L18.8788 16.0547L19.5877 19.1454C19.8818 20.4317 19.7843 21.7073 18.8771 22.3742C17.9667 23.0433 16.7227 22.7467 15.5925 22.0736L12.6026 20.289C12.477 20.214 12.2614 20.1532 12.0011 20.1532C11.7427 20.1532 11.5226 20.2132 11.3888 20.291L11.3869 20.2921L8.40288 22.0732C7.27405 22.7487 6.03154 23.04 5.12111 22.3702C4.21449 21.7032 4.11214 20.43 4.40711 19.1447L5.1159 16.0547L5.11633 16.0527C5.14741 15.9107 5.14133 15.6908 5.0728 15.4494C5.0038 15.2064 4.89379 15.0199 4.79558 14.9209L2.31585 12.4206C1.49265 11.5906 1.03521 10.5704 1.34595 9.58925C1.65759 8.60525 2.62143 8.0398 3.77433 7.84606L6.96132 7.31219L6.96233 7.31202C7.07917 7.29175 7.2627 7.21456 7.45248 7.07268C7.64261 6.93054 7.76959 6.77535 7.82312 6.66516L7.82582 6.65967L9.58562 3.11097L9.58632 3.10957C10.119 2.04108 10.948 1.25 11.9961 1.25Z"
                    fill="currentColor"></path>
                </svg>
              </label>
            {% endfor %}
          </div>
        </div>
      </div>
      <div class="fields">
        <div class="field">
          <label ui-slot="label" for="first-name">
            {{ 'reviews.add_review.fields.first_name.label' | t }}
          </label>
          <input
            ui-slot="input"
            data-size="md"
            required
            type="text"
            id="first-name"
            name="first-name"
            placeholder="{{ 'reviews.add_review.fields.first_name.placeholder' | t }}"
          >
        </div>
        <div class="field">
          <label ui-slot="label" for="last-name">
            {{ 'reviews.add_review.fields.last_name.label' | t }}
          </label>
          <input
            ui-slot="input"
            data-size="md"
            required
            type="text"
            id="last-name"
            name="last-name"
            placeholder="{{ 'reviews.add_review.fields.last_name.placeholder' | t }}"
          >
        </div>
        <div class="field">
          <label ui-slot="label" for="email">
            {{ 'reviews.add_review.fields.email_address.label' | t }}
          </label>
          <input
            ui-slot="input"
            data-size="md"
            required
            type="email"
            id="email"
            name="email"
            placeholder="{{ 'reviews.add_review.fields.email_address.placeholder' | t }}"
          >
        </div>
        <div class="field">
          <label ui-slot="label" for="content">
            {{ 'reviews.add_review.fields.review.label' | t }}
          </label>
          <textarea
            ui-slot="textarea"
            required
            type="text"
            id="content"
            name="content"
            minlength="5"
            placeholder="{{ 'reviews.add_review.fields.review.placeholder' | t }}"
          ></textarea>
        </div>
        <div class="field">
          <label for="images">
            {{ 'reviews.add_review.fields.images.label' | t }}
          </label>
          <div class="images">
            <label
              ui-slot="button"
              data-variant="primary"
              data-mode="stroke"
              data-size="md"
              class="upload"
            >
              {% render 'misc.icon', name: 'hgi-cloud-upload' %}
              <input
                multiple
                type="file"
                id="images"
                name="images"
                accept="image/png, image/gif, image/jpeg, image/jpg, image/webp"
                ui-add-review="upload-image"
              >
            </label>
            <template ui-add-review="image">
              <div class="image">
                <img
                  alt="image"
                  width="60"
                  height="60"
                  loading="lazy"
                >
                <button
                  ui-slot="compact-button"
                  data-size="md"
                  aria-label="Remove"
                  type="button"
                  ui-add-review="remove-image"
                >
                  {% render 'misc.icon', name: 'hgi-cancel-01' %}
                </button>
              </div>
            </template>
          </div>
        </div>
      </div>
    </div>
    <div ui-slot="modal-footer">
      <button
        ui-slot="button"
        data-variant="primary"
        data-mode="stroke"
        data-size="lg"
        popovertarget="add-review"
        type="button"
      >
        {{ 'general.cancel' | t }}
      </button>
      <button
        ui-slot="button"
        data-variant="primary"
        data-mode="filled"
        data-size="lg"
        type="submit"
        ui-add-review="submit"
      >
        {{ 'general.submit' | t }}
      </button>
    </div>
  </form>
</ui-add-review>
