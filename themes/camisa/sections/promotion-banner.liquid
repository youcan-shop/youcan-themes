{{ 'section.promotion-banner.css' | asset_url | stylesheet_tag }}

<div
  ui-section="promotion-banner"
  role="banner"
  {% if section.settings.override_global_colors %}
    style="
      --brand-lightness: {{ section.settings.main_color.lightness | divided_by: 100 }};
      --brand-chroma: {{ section.settings.main_color.chroma }};
      --brand-hue: {{ section.settings.main_color.oklch_hue }};
    "
    data-scoped-color
    data-intensity="{{ section.settings.color_intensity }}"
  {% endif %}
>
  <ui-marquee
    {% if section.settings.pause_on_hover %}
      data-pause-on-hover
    {% endif %}
    speed="{{ section.settings.speed }}"
  >
    <div ui-marquee="track">
      <ul ui-marquee="cloud">
        {% for item in section.blocks %}
          <li ui-marquee="item" {{ item.youcan_attributes }}>
            {% if item.settings.link %}
              <a
                ui-slot="link-button"
                data-size="md"
                data-underline="true"
                href="{{ item.settings.link }}"
              >
                {{ item.settings.text }}
              </a>
            {% else %}
              <span>
                {{ item.settings.text }}
              </span>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    </div>
  </ui-marquee>
</div>

{% schema %}
{
  "label": "t:sections.promotion_banner.label",
  "templates": ["index", "product", "page", "cart"],
  "tag": "header",
  "limit": 2,
  "max_blocks": 10,
  "settings": [
    {
      "type": "header",
      "content": "t:common.headers.colors"
    },
    {
      "type": "checkbox",
      "id": "override_global_colors",
      "label": "t:common.colors.override_global_colors",
      "default": true
    },
    {
      "type": "color",
      "id": "main_color",
      "label": "t:common.colors.main_color",
      "default": "#121212"
    },
    {
      "type": "select",
      "id": "color_intensity",
      "label": "t:common.colors.color_intensity",
      "options": [
        { "label": "t:common.colors.options.as_solid_bg", "value": "as-solid-bg" },
        { "label": "t:common.colors.options.as_light_bg", "value": "as-light-bg" },
        { "label": "t:common.colors.options.as_foreground", "value": "as-foreground" }
      ],
      "default": "as-solid-bg"
    },
    {
      "type": "header",
      "content": "t:common.headers.motion"
    },
    {
      "type": "select",
      "id": "speed",
      "label": "t:sections.promotion_banner.speed.label",
      "options": [
        {
          "value": "20",
          "label": "t:sections.promotion_banner.speed.options.slow"
        },
        {
          "value": "60",
          "label": "t:sections.promotion_banner.speed.options.normal"
        },
        {
          "value": "80",
          "label": "t:sections.promotion_banner.speed.options.fast"
        }
      ],
      "default": "60"
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "t:sections.promotion_banner.pause_on_hover",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "item",
      "label": "t:sections.promotion_banner.blocks.item.label",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "t:sections.promotion_banner.blocks.item.text",
          "default": "t:sections.promotion_banner.blocks.item.default"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.promotion_banner.blocks.item.link",
          "default": ""
        }
      ]
    }
  ]
}
{% endschema %}
