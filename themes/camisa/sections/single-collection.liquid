{{ 'section.single-collection.css' | asset_url | stylesheet_tag }}

<div
  ui-section="single-collection"
  {% if section.settings.override_global_colors %}
    style="
      --brand-lightness: {{ section.settings.main_color.lightness | divided_by: 100 }};
      --brand-chroma: {{ section.settings.main_color.chroma }};
      --brand-hue: {{ section.settings.main_color.oklch_hue }};
    "
    data-scoped-color
    data-intensity="{{ section.settings.color_intensity }}"
  {% endif %}
  data-top-spacing="{{ section.settings.top_spacing }}"
  data-bottom-spacing="{{ section.settings.bottom_spacing }}"
>
  <div class="cover-area">
    <h1 class="heading">{{ category.name }}</h1>
    {% if category.description %}
      <p class="description">{{ category.description }}</p>
    {% endif %}
    {% if category.image %}
      <img src="{{ category.image }}" alt="{{ category.name }}" height="100%" width="100%">
    {% endif %}
  </div>
  {% paginate collection.products by 24 cod, category_id: category.id %}
    {% if subCategories.size > 0 %}
      <ul class="sub-collections-area">
        {% for subCollection in subCategories %}
          <li class="sub-collection">
            <a ui-slot="link-button" data-size="md" href="/collections/{{ subCollection.slug }}">
              {{ subCollection.name }}
            </a>
          </li>
        {% endfor %}
      </ul>
    {% endif %}
    {% render 'misc.sort', url: previous_page %}
    <div class="core-area">
      {% if items.size > 0 %}
        <ul class="items" data-nbr-columns-desktop="{{ section.settings.nbr_columns_desktop }}">
          {% for product in items %}
            {% render 'block.product', product: product %}
          {% endfor %}
        </ul>

        {% render 'misc.pagination', next_page_url: next_page, previous_page_url: previous_page, current: current, last: last, terms: terms %}

      {% else %}
        {% assign empty_content = 'single-collection.empty.title' | t %}
        {% assign empty_action = 'single-collection.empty.action' | t %}
        {% render 'misc.empty', heading: empty_content, action_label: empty_action, action_url: '/search' %}
      {% endif %}
    </div>
  {% endpaginate %}
</div>

{% schema %}
{
  "label": "t:sections.collection.label",
  "templates": ["collection"],
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "t:common.headers.colors"
    },
    {
      "type": "checkbox",
      "id": "override_global_colors",
      "label": "t:common.colors.override_global_colors",
      "default": false
    },
    {
      "type": "color",
      "id": "main_color",
      "label": "t:common.colors.main_color",
      "default": "#121212"
    },
    {
      "type": "select",
      "id": "color_intensity",
      "label": "t:common.colors.color_intensity",
      "options": [
        { "label": "t:common.colors.options.as_solid_bg", "value": "as-solid-bg" },
        { "label": "t:common.colors.options.as_light_bg", "value": "as-light-bg" },
        { "label": "t:common.colors.options.as_foreground", "value": "as-foreground" }
      ],
      "default": "as-foreground"
    },
    {
      "type": "header",
      "content": "t:common.headers.layout"
    },
    {
      "type": "range",
      "id": "nbr_columns_desktop",
      "label": "t:common.globals.number_per_column",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_discount_badge",
      "label": "t:sections.collection.show_discount_badge",
      "default": true
    },
    {
      "type": "header",
      "content": "t:common.headers.spacing"
    },
    {
      "type": "range",
      "id": "top_spacing",
      "label": "t:common.spacing.top_spacing",
      "min": 0,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "bottom_spacing",
      "label": "t:common.spacing.bottom_spacing",
      "min": 0,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ]
}
{% endschema %}
