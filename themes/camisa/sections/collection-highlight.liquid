{{ 'section.collection-highlight.css' | asset_url | stylesheet_tag }}

<div
  ui-section="collection-highlight"
  {% if section.settings.override_global_colors %}
    style="
      --brand-lightness: {{ section.settings.main_color.lightness | divided_by: 100 }};
      --brand-chroma: {{ section.settings.main_color.chroma }};
      --brand-hue: {{ section.settings.main_color.oklch_hue }};
    "
    data-scoped-color
    data-intensity="{{ section.settings.color_intensity }}"
  {% endif %}
  data-top-spacing="{{ section.settings.top_spacing }}"
  data-bottom-spacing="{{ section.settings.bottom_spacing }}"
>
  <ul
    class="items-area"
    data-nbr-columns-desktop="{{ section.settings.nbr_columns_desktop }}"
    data-nbr-columns-mobile="{{ section.settings.nbr_columns_mobile }}"
  >
    <li style="background-image: url({{ section.settings.image.src }});">
      <div
        ui-block="content"
        data-text-alignment="{{ section.settings.text_alignment }}"
        data-vertical-alignment="{{ section.settings.vertical_alignment }}"
        {% if section.settings.image %}
          data-has-image="true"
        {% endif %}
      >
        <h1 class="heading">{{ section.settings.heading }}</h1>
        <p class="description">{{ section.settings.description }}</p>
        <a
          class="cta"
          {% if section.settings.button_style == 'underline' %}
            ui-slot="link-button"
            data-underline="true"
          {% else %}
            ui-slot="button"
            data-variant="primary"
          {% endif %}
          {% if section.settings.button_style == 'primary' %}
            data-mode="filled"
          {% elsif section.settings.button_style == 'secondary' %}
            data-mode="stroke"
          {% endif %}
          data-size="lg"
          href="{{ section.settings.button_link }}"
        >
          {{ section.settings.button_label }}
        </a>
      </div>
    </li>
    {% assign max_products = section.settings.max_products_to_show %}
    {% if section.settings.collection.id %}
      {% paginate collection.products by max_products id category_id: section.settings.collection.id %}
        {% for product in items %}
          {% render 'block.product', product: product %}
        {% endfor %}
      {% endpaginate %}
    {% else %}
      {% for product in (1..max_products) %}
        {% render 'block.product' %}
      {% endfor %}
    {% endif %}
  </ul>
</div>

{% schema %}
{
  "label": "t:sections.collection_highlight.label",
  "templates": ["index", "product", "page", "cart"],
  "limit": 3,
  "settings": [
    {
      "type": "header",
      "content": "t:common.headers.general"
    },
    {
      "type": "category",
      "id": "collection",
      "label": "t:common.globals.collection"
    },
    {
      "type": "header",
      "content": "t:common.headers.colors"
    },
    {
      "type": "checkbox",
      "id": "override_global_colors",
      "label": "t:common.colors.override_global_colors",
      "default": false
    },
    {
      "type": "color",
      "id": "main_color",
      "label": "t:common.colors.main_color",
      "default": "#121212"
    },
    {
      "type": "select",
      "id": "color_intensity",
      "label": "t:common.colors.color_intensity",
      "options": [
        { "label": "t:common.colors.options.as_solid_bg", "value": "as-solid-bg" },
        { "label": "t:common.colors.options.as_light_bg", "value": "as-light-bg" },
        { "label": "t:common.colors.options.as_foreground", "value": "as-foreground" }
      ],
      "default": "as-foreground"
    },
    {
      "type": "header",
      "content": "t:common.headers.banner"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:common.header.heading",
      "default": "t:sections.collection_highlight.default.heading"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:common.header.description",
      "default": "t:sections.collection_highlight.default.description"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:common.button.label",
      "default": "t:sections.collection_highlight.default.link"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:common.button.link",
      "default": "#"
    },
    {
      "type": "select",
      "id": "button_style",
      "options": [
        { "label": "t:common.button.style.options.primary", "value": "primary" },
        { "label": "t:common.button.style.options.secondary", "value": "secondary" },
        { "label": "t:common.button.style.options.underline", "value": "underline" }
      ],
      "label": "t:common.button.style.label",
      "default": "underline"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "t:common.globals.text_alignment",
      "options": [
        { "label": "t:common.layout.alignment.start", "value": "start" },
        { "label": "t:common.layout.alignment.center", "value": "center" },
        { "label": "t:common.layout.alignment.end", "value": "end" }
      ],
      "default": "start"
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "t:common.globals.vertical_alignment",
      "options": [
        { "label": "t:common.layout.vertical_alignment.top", "value": "start" },
        { "label": "t:common.layout.vertical_alignment.middle", "value": "center" },
        { "label": "t:common.layout.vertical_alignment.bottom", "value": "end" }
      ],
      "default": "center"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:common.globals.image"
    },
    {
      "type": "header",
      "content": "t:common.headers.layout"
    },
    {
      "type": "checkbox",
      "id": "show_discount_badge",
      "label": "t:sections.collection_highlight.show_discount_badge",
      "default": true
    },
    {
      "type": "range",
      "id": "nbr_columns_desktop",
      "label": "t:common.globals.number_per_column",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "max_products_to_show",
      "label": "t:common.globals.max_products",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "header",
      "content": "t:common.headers.mobile_layout"
    },
    {
      "type": "select",
      "id": "nbr_columns_mobile",
      "label": "t:common.globals.number_per_column_mobile",
      "options": [
        { "label": "t:common.layout.column.one", "value": "1" },
        { "label": "t:common.layout.column.two", "value": "2" }
      ],
      "default": "2"
    },
    {
      "type": "header",
      "content": "t:common.headers.spacing"
    },
    {
      "type": "range",
      "id": "top_spacing",
      "label": "t:common.spacing.top_spacing",
      "min": 0,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "bottom_spacing",
      "label": "t:common.spacing.bottom_spacing",
      "min": 0,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ]
}
{% endschema %}
